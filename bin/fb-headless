#!/usr/bin/env bash
# fb-headless — manages a dedicated headless Chrome for fb on :9223.
#
# Why its own user-data-dir? Because Chrome's SingletonLock prevents
# running a second instance against the same profile. The visible Chrome
# (on ~/.config/google-chrome/Default) is the user's normal browser; the
# headless Chrome here lives in its own user-data-dir with a *minimal*
# copy and runs in parallel without conflict.
#
# What lives in the headless profile:
#   - OpenCLI extension files only (bridge → opencli daemon)
#   - Full Preferences + Secure Preferences (needed so Chrome trusts OpenCLI;
#     other extension paths are missing and simply fail to load)
#   - Facebook cookies + Local State (decrypt key)
#
# Why not "slim Preferences to OpenCLI only"? Chrome's Secure Preferences
# HMAC then disables the bridge. Full prefs + missing sibling ext dirs is
# the reliable ~few-MB path (verified).
#
# Usage:
#   fb-headless start|stop|restart|status|logs|reset
#
# Environment:
#   FB_CHROME_PORT                  CDP port (default 9223)
#   FB_HEADLESS_USER_DATA           default ~/.local/state/fb/chrome
#   FB_HEADLESS_PROFILE_DIR         default Default
#   FB_SOURCE_PROFILE               default ~/.config/google-chrome/Default
#   FB_CHROME_BIN                   auto-detect
#   FB_CHROME_LOG                   default ~/.local/state/fb/chrome.log

set -euo pipefail

PORT="${FB_CHROME_PORT:-9223}"
HEADLESS_USER_DATA="${FB_HEADLESS_USER_DATA:-$HOME/.local/state/fb/chrome}"
HEADLESS_PROFILE_DIR="${FB_HEADLESS_PROFILE_DIR:-Default}"
SOURCE_PROFILE="${FB_SOURCE_PROFILE:-$HOME/.config/google-chrome/Default}"
OPENCLI_ID="ildkmabpimmkaediidaifkhjpohdnifk"

find_chrome() {
  if [ -n "${FB_CHROME_BIN:-}" ] && [ -x "$FB_CHROME_BIN" ]; then
    echo "$FB_CHROME_BIN"; return 0
  fi
  for name in google-chrome google-chrome-stable chromium chromium-browser chrome; do
    if command -v "$name" >/dev/null 2>&1; then
      command -v "$name"; return 0
    fi
  done
  for c in \
    /usr/bin/google-chrome \
    /usr/bin/google-chrome-stable \
    /usr/bin/chromium \
    /usr/bin/chromium-browser \
    /opt/google/chrome/chrome \
    /snap/bin/chromium
  do
    [ -x "$c" ] && { echo "$c"; return 0; }
  done
  return 1
}
CHROME="$(find_chrome 2>/dev/null || true)"
[ -z "$CHROME" ] && CHROME="/usr/bin/google-chrome"
LOG="${FB_CHROME_LOG:-$HOME/.local/state/fb/chrome.log}"
PIDFILE="$HOME/.local/state/fb/chrome.pid"
HEADLESS_PROFILE="$HEADLESS_USER_DATA/$HEADLESS_PROFILE_DIR"

log() { echo "[fb-headless] $*" >&2; }
die() { echo "fb-headless: $*" >&2; exit "${2:-1}"; }

probe_cdp() {
  curl -s --max-time 2 "http://127.0.0.1:$PORT/json/version" >/dev/null 2>&1
}

chrome_pids_for_port() {
  for pid in $(pgrep -x chrome 2>/dev/null) $(pgrep -x google-chrome 2>/dev/null) $(pgrep -x google-chrome-stable 2>/dev/null); do
    [ -r "/proc/$pid/cmdline" ] || continue
    local cmdline
    cmdline=$(tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null)
    if printf '%s' "$cmdline" | grep -qE "(^| )--remote-debugging-port=${PORT}( |$)"; then
      echo "$pid"
    fi
  done
}

profile_is_heavy() {
  # OpenCLI-only Extensions tree is expected; extra ext dirs → heavy.
  if [ -d "$HEADLESS_PROFILE/Extensions" ]; then
    local n
    n=$(find "$HEADLESS_PROFILE/Extensions" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    [ "${n:-0}" -gt 1 ] && return 0
  fi
  local disk_kb
  disk_kb=$(du -sk "$HEADLESS_USER_DATA" 2>/dev/null | awk '{print $1}')
  # Allow some runtime cache; rebuild if component updates bloat past 80MB
  [ "${disk_kb:-0}" -gt 250000 ] && return 0  # >250MB = heavy
  return 1
}

# Minimal copy that keeps the OpenCLI bridge trusted by Chrome.
copy_profile() {
  if [ ! -d "$SOURCE_PROFILE" ]; then
    die "source profile not found: $SOURCE_PROFILE (Chrome installed?)" 1
  fi

  if [ -d "$HEADLESS_PROFILE" ] && [ -f "$HEADLESS_PROFILE/Cookies" ] && [ -f "$HEADLESS_PROFILE/Preferences" ]; then
    if ! profile_is_heavy; then
      return 0
    fi
    log "existing headless profile is heavy — re-building minimal copy"
    rm -rf "$HEADLESS_PROFILE"
  fi

  log "first start: minimal copy from $SOURCE_PROFILE → $HEADLESS_PROFILE"
  mkdir -p "$HEADLESS_PROFILE"

  # 1. OpenCLI extension files only (other prefs entries will no-op / fail)
  if [ -d "$SOURCE_PROFILE/Extensions/$OPENCLI_ID" ]; then
    mkdir -p "$HEADLESS_PROFILE/Extensions"
    cp -a "$SOURCE_PROFILE/Extensions/$OPENCLI_ID" "$HEADLESS_PROFILE/Extensions/"
    log "  + opencli extension ($(du -sk "$HEADLESS_PROFILE/Extensions/$OPENCLI_ID" | awk '{print $1}')KB)"
  else
    log "  ! WARNING: opencli extension not found in source — bridge won't connect"
  fi

  # 2. Cookies (encrypted; needs Local State)
  if [ -f "$SOURCE_PROFILE/Cookies" ]; then
    cp "$SOURCE_PROFILE/Cookies" "$HEADLESS_PROFILE/Cookies"
    log "  + Cookies ($(du -sk "$HEADLESS_PROFILE/Cookies" | awk '{print $1}')KB)"
  else
    log "  ! WARNING: no Cookies in source — Facebook session missing"
  fi

  # 3. Login Data (optional)
  if [ -f "$SOURCE_PROFILE/Login Data" ]; then
    cp "$SOURCE_PROFILE/Login Data" "$HEADLESS_PROFILE/Login Data"
    log "  + Login Data"
  fi

  # 4. Preferences + Secure Preferences UNMODIFIED (HMAC / extension trust)
  if [ -f "$SOURCE_PROFILE/Preferences" ]; then
    cp "$SOURCE_PROFILE/Preferences" "$HEADLESS_PROFILE/Preferences"
    log "  + Preferences (unmodified — required for OpenCLI trust)"
  fi
  if [ -f "$SOURCE_PROFILE/Secure Preferences" ]; then
    cp "$SOURCE_PROFILE/Secure Preferences" "$HEADLESS_PROFILE/Secure Preferences"
    log "  + Secure Preferences"
  fi

  # 5. Local State at user-data-dir (cookie encryption key)
  if [ -f "$SOURCE_PROFILE/../Local State" ]; then
    cp "$SOURCE_PROFILE/../Local State" "$HEADLESS_USER_DATA/Local State"
    log "  + Local State (user-data-dir)"
  fi

  # 6. First Run marker
  if [ -f "$SOURCE_PROFILE/../First Run" ]; then
    cp "$SOURCE_PROFILE/../First Run" "$HEADLESS_USER_DATA/First Run"
  fi

  # 7. Facebook IndexedDB — Messenger history / E2EE device state (LS / maw_ear).
  #    Without this, scroll-up history often hangs on "Loading..." forever and only
  #    the initial ~page of messages is available.
  copy_facebook_indexeddb

  # Trim non-FB cookies *before* Chrome starts (never overwrite a live Cookies DB).
  purge_non_facebook_cookies

  log "minimal profile copied"
}

# Copy only facebook.com IndexedDB from the real profile (not every site).
copy_facebook_indexeddb() {
  local src_idb="$SOURCE_PROFILE/IndexedDB"
  local dst_idb="$HEADLESS_PROFILE/IndexedDB"
  local name="https_www.facebook.com_0.indexeddb"
  if [ ! -d "$src_idb/${name}.leveldb" ] && [ ! -d "$src_idb/${name}.blob" ]; then
    log "  ! no Facebook IndexedDB in source (Messenger history may be incomplete)"
    return 0
  fi
  mkdir -p "$dst_idb"
  # Source Chrome may hold locks; copy what we can.
  if [ -d "$src_idb/${name}.leveldb" ]; then
    rm -rf "$dst_idb/${name}.leveldb"
    if cp -a "$src_idb/${name}.leveldb" "$dst_idb/${name}.leveldb" 2>/dev/null; then
      log "  + IndexedDB facebook leveldb ($(du -sk "$dst_idb/${name}.leveldb" | awk '{print $1}')KB)"
    else
      # Fallback: copy files ignoring LOCK
      mkdir -p "$dst_idb/${name}.leveldb"
      find "$src_idb/${name}.leveldb" -type f ! -name 'LOCK' -exec cp -a {} "$dst_idb/${name}.leveldb/" \; 2>/dev/null || true
      log "  + IndexedDB facebook leveldb (best-effort copy)"
    fi
  fi
  if [ -d "$src_idb/${name}.blob" ]; then
    rm -rf "$dst_idb/${name}.blob"
    cp -a "$src_idb/${name}.blob" "$dst_idb/${name}.blob" 2>/dev/null || true
    log "  + IndexedDB facebook blob ($(du -sk "$dst_idb/${name}.blob" 2>/dev/null | awk '{print $1}')KB)"
  fi
}

purge_non_facebook_cookies() {
  local cookies_db="$HEADLESS_PROFILE/Cookies"
  [ -f "$cookies_db" ] || return 0
  command -v sqlite3 >/dev/null 2>&1 || return 0
  local tmp="${cookies_db}.trim"
  cp "$cookies_db" "$tmp" 2>/dev/null || return 0
  local deleted
  deleted=$(sqlite3 "$tmp" "
    DELETE FROM cookies
    WHERE host_key NOT LIKE '%.facebook.com'
      AND host_key NOT LIKE '%.messenger.com'
      AND host_key NOT LIKE '%.fb.com'
      AND host_key NOT LIKE '%.fbcdn.net'
      AND host_key NOT LIKE '%.fbsbx.com'
      AND host_key NOT LIKE '%.fb.gg'
      AND host_key NOT LIKE '%.facebook.net'
      AND host_key NOT LIKE '%.fbcdn.com'
      AND host_key NOT IN (
        'facebook.com','messenger.com','fb.com','fbcdn.net',
        'fbsbx.com','fb.gg','facebook.net','fbcdn.com'
      );
    SELECT changes();
  " 2>/dev/null || echo 0)
  if [ -n "$deleted" ] && [ "$deleted" -gt 0 ] 2>/dev/null; then
    if cp "$tmp" "$cookies_db" 2>/dev/null; then
      log "  ✓ purged $deleted non-fb cookies ($(du -sk "$cookies_db" | awk '{print $1}')KB remaining)"
    else
      log "  ~ purged $deleted non-fb cookies in temp (live Cookies locked)"
    fi
  fi
  rm -f "$tmp"
}

wait_for_bridge() {
  # OpenCLI SW needs a moment after Chrome starts; daemon must already be up.
  local i
  for i in $(seq 1 20); do
    if curl -s --max-time 1 -H 'X-OpenCLI: 1' http://127.0.0.1:19825/status 2>/dev/null \
      | grep -q '"extensionConnected":true'; then
      log "  ✓ OpenCLI bridge connected"
      return 0
    fi
    sleep 0.5
  done
  log "  ! OpenCLI bridge not connected yet (daemon on :19825? extension in source Chrome?)"
  return 1
}

cmd_start() {
  mkdir -p "$(dirname "$LOG")" "$(dirname "$PIDFILE")" "$HEADLESS_USER_DATA"

  if probe_cdp; then
    local pids
    pids=$(chrome_pids_for_port | tr '\n' ' ')
    if profile_is_heavy; then
      log "CDP up but profile is heavy — restarting with minimal profile"
      cmd_stop || true
      sleep 0.4
    else
      log "headless Chrome already serving CDP on :$PORT (pids: ${pids:-none})"
      echo "${pids%% *}" > "$PIDFILE" 2>/dev/null || true
      wait_for_bridge || true
      return 0
    fi
  fi

  copy_profile

  log "launching headless Chrome on :$PORT  user-data=$HEADLESS_USER_DATA  profile=$HEADLESS_PROFILE_DIR"
  nohup "$CHROME" \
    --headless=new \
    --no-sandbox \
    --disable-gpu \
    --disable-dev-shm-usage \
    --disable-software-rasterizer \
    --no-first-run \
    --no-default-browser-check \
    --disable-session-cracked-bubble \
    --disable-features=TranslateUI,MediaRouter,OptimizationHints \
    --noerrdialogs \
    --disable-background-networking \
    --disable-background-timer-throttling \
    --disable-backgrounding-occluded-windows \
    --disable-breakpad \
    --disable-client-side-phishing-detection \
    --disable-component-update \
    --disable-default-apps \
    --disable-domain-reliability \
    --disable-hang-monitor \
    --disable-ipc-flooding-protection \
    --disable-popup-blocking \
    --disable-prompt-on-repost \
    --disable-renderer-backgrounding \
    --disable-sync \
    --metrics-recording-only \
    --mute-audio \
    --user-data-dir="$HEADLESS_USER_DATA" \
    --profile-directory="$HEADLESS_PROFILE_DIR" \
    --remote-debugging-port="$PORT" \
    --remote-allow-origins='*' \
    --remote-debugging-address=127.0.0.1 \
    about:blank \
    >"$LOG" 2>&1 &
  local pid=$!
  echo "$pid" > "$PIDFILE"
  disown "$pid" 2>/dev/null || true

  local waited=0
  while [ $waited -lt 100 ]; do
    if probe_cdp; then
      log "CDP ready on :$PORT after ${waited}00ms  (chrome pid=$pid)"
      sleep 0.8
      wait_for_bridge || true
      cmd_status
      return 0
    fi
    sleep 0.1
    waited=$((waited + 1))
  done
  log "Chrome started but CDP never came up on :$PORT"
  log "Last 20 log lines:"
  tail -20 "$LOG" >&2 || true
  return 1
}

cmd_stop() {
  local pids
  pids=$(chrome_pids_for_port)
  if [ -z "$pids" ]; then
    log "no headless Chrome on :$PORT"
    rm -f "$PIDFILE"
    return 0
  fi
  log "stopping pids: $pids"
  echo "$pids" | xargs -r kill 2>/dev/null || true
  sleep 0.5
  echo "$pids" | xargs -r kill -9 2>/dev/null || true
  rm -f "$PIDFILE"
  log "stopped"
}

cmd_restart() {
  cmd_stop || true
  sleep 0.3
  cmd_start
}

cmd_status() {
  local pids
  pids=$(chrome_pids_for_port)
  if [ -z "$pids" ]; then
    echo "fb-headless: not running on :$PORT"
    return 1
  fi
  local rss_kb=0
  for p in $pids; do
    local rss
    rss=$(ps -o rss= -p "$p" 2>/dev/null | tr -d ' ' || echo 0)
    rss_kb=$((rss_kb + ${rss:-0}))
  done
  local rss_mb=$((rss_kb / 1024))
  local disk bridge
  disk=$(du -sh "$HEADLESS_USER_DATA" 2>/dev/null | awk '{print $1}')
  bridge="no"
  if curl -s --max-time 1 -H 'X-OpenCLI: 1' http://127.0.0.1:19825/status 2>/dev/null \
    | grep -q '"extensionConnected":true'; then
    bridge="yes"
  fi
  if probe_cdp; then
    local ver
    ver=$(curl -s --max-time 2 "http://127.0.0.1:$PORT/json/version" 2>/dev/null \
      | grep -o '"Browser":[^,]*' | head -1 | sed 's/.*: *"\(.*\)"/\1/')
    echo "fb-headless: running  port=$PORT  rss=${rss_mb}MB  disk=${disk:-?}  bridge=$bridge  browser=$ver"
    return 0
  fi
  echo "fb-headless: chrome process exists but CDP not reachable on :$PORT"
  return 1
}

cmd_logs() {
  local n="${1:-40}"
  tail -n "$n" "$LOG"
}

cmd_reset() {
  log "removing headless user-data-dir at $HEADLESS_USER_DATA"
  cmd_stop || true
  rm -rf "$HEADLESS_USER_DATA"
  rm -f "$PIDFILE"
  log "done — next start will re-copy from $SOURCE_PROFILE"
}

case "${1:-status}" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    shift; cmd_logs "${1:-40}" ;;
  reset)   cmd_reset ;;
  -h|--help|help)
    sed -n '2,30p' "$0" | sed 's/^# \?//'
    ;;
  *) die "unknown subcommand: $1 (try: start|stop|restart|status|logs|reset)" 2 ;;
esac
