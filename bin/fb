#!/usr/bin/env node
/**
 * fb — Facebook/Messenger CLI (bird / wacli style UX on top of opencli)
 *
 * Requires: opencli + Chrome OpenCLI extension (opencli doctor)
 * Store:    ~/.local/state/fb/
 */
import { spawn, spawnSync } from 'node:child_process';
import fs from 'node:fs';
import os from 'node:os';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { createRequire } from 'node:module';

const VERSION = '0.4.0';
const STORE_DIR = process.env.FB_STORE_DIR || path.join(os.homedir(), '.local/state/fb');
const DB_PATH = path.join(STORE_DIR, 'fb.db');
const DAEMON_STATE = path.join(STORE_DIR, 'daemon.json');
// Default: invisible backend (opencli background windows). Override with --window foreground.
const DEFAULT_WINDOW = process.env.FB_WINDOW || process.env.OPENCLI_WINDOW || 'background';

function ensureStore() {
  fs.mkdirSync(STORE_DIR, { recursive: true });
  fs.mkdirSync(path.join(STORE_DIR, 'cache'), { recursive: true });
  const schema = `
CREATE TABLE IF NOT EXISTS meta (
  key TEXT PRIMARY KEY,
  value TEXT NOT NULL,
  updated_at TEXT NOT NULL
);
CREATE TABLE IF NOT EXISTS notifications (
  notif_id TEXT PRIMARY KEY,
  unread INTEGER,
  text TEXT,
  time TEXT,
  url TEXT,
  notif_type TEXT,
  synced_at TEXT NOT NULL
);
CREATE TABLE IF NOT EXISTS groups (
  url TEXT PRIMARY KEY,
  name TEXT,
  last_post TEXT,
  synced_at TEXT NOT NULL
);
CREATE TABLE IF NOT EXISTS chats (
  thread_id TEXT PRIMARY KEY,
  name TEXT,
  snippet TEXT,
  time TEXT,
  unread INTEGER,
  url TEXT,
  synced_at TEXT NOT NULL
);
CREATE TABLE IF NOT EXISTS messages (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  thread_id TEXT NOT NULL,
  from_me INTEGER,
  sender TEXT,
  text TEXT,
  time TEXT,
  synced_at TEXT NOT NULL
);
CREATE INDEX IF NOT EXISTS idx_messages_thread ON messages(thread_id);
`;
  runSql(schema);
}

function runSql(sql, params = []) {
  ensureDirOnly();
  // Use sqlite3 CLI for zero npm deps
  if (params.length) {
    // parameterize poorly via JSON for simple cases - prefer direct for our writes
  }
  const r = spawnSync('sqlite3', [DB_PATH], {
    input: sql,
    encoding: 'utf8',
    maxBuffer: 20 * 1024 * 1024,
  });
  if (r.status !== 0) {
    const err = (r.stderr || r.stdout || 'sqlite3 failed').trim();
    throw new Error(err || `sqlite3 exit ${r.status}`);
  }
  return r.stdout;
}

function ensureDirOnly() {
  fs.mkdirSync(STORE_DIR, { recursive: true });
}

function sqlEscape(s) {
  return String(s ?? '').replace(/'/g, "''");
}

function nowIso() {
  return new Date().toISOString();
}

function whichOpencli() {
  const candidates = [
    process.env.OPENCLI_BIN,
    path.join(os.homedir(), '.npm-global/bin/opencli'),
    '/usr/local/bin/opencli',
    'opencli',
  ].filter(Boolean);
  for (const c of candidates) {
    if (c === 'opencli') return c;
    try {
      fs.accessSync(c, fs.constants.X_OK);
      return c;
    } catch {
      /* next */
    }
  }
  return 'opencli';
}

const OPENCLI = whichOpencli();

function parseGlobalArgs(argv) {
  const out = {
    json: false,
    plain: false,
    limit: null,
    window: null,
    help: false,
    version: false,
    rest: [],
  };
  const args = [...argv];
  // Allow global flags anywhere (before or after the subcommand)
  while (args.length) {
    const a = args.shift();
    if (a === '--json' || a === '-j') out.json = true;
    else if (a === '--plain') out.plain = true;
    else if (a === '--help' || a === '-h') out.help = true;
    else if (a === '--version' || a === '-V') out.version = true;
    else if (a === '--limit' || a === '-n') out.limit = args.shift();
    else if (a === '--window') out.window = args.shift();
    else if (a === '--store') process.env.FB_STORE_DIR = args.shift();
    else out.rest.push(a);
  }
  return out;
}

function opencli(args, { json = true, timeout = 180000, windowMode } = {}) {
  const cmdArgs = [...args];
  if (json && !cmdArgs.includes('-f') && !cmdArgs.includes('--format')) {
    cmdArgs.push('-f', 'json');
  }
  // Force background unless caller already set --window.
  // Put flags at the END so `facebook whoami --window background` parses correctly.
  const hasWindow = cmdArgs.includes('--window');
  const mode = windowMode || DEFAULT_WINDOW;
  if (!hasWindow && (mode === 'background' || mode === 'foreground')) {
    // only for browser-backed commands (facebook / browser)
    if (cmdArgs[0] === 'facebook' || cmdArgs[0] === 'browser') {
      cmdArgs.push('--window', mode);
    }
  }
  const env = {
    ...process.env,
    OPENCLI_WINDOW: mode,
  };
  const r = spawnSync(OPENCLI, cmdArgs, {
    encoding: 'utf8',
    maxBuffer: 30 * 1024 * 1024,
    timeout,
    env,
  });
  return {
    status: r.status ?? 1,
    stdout: r.stdout || '',
    stderr: r.stderr || '',
    error: r.error,
  };
}

function hideChromeWindows() {
  // Best-effort: keep Chrome running for the extension, but off-screen / minimized.
  try {
    const list = spawnSync('wmctrl', ['-l'], { encoding: 'utf8' });
    if (list.status !== 0 || !list.stdout) return { ok: false, reason: 'wmctrl unavailable' };
    const lines = list.stdout.split('\n').filter((l) => /chrome|chromium|google-chrome/i.test(l));
    let n = 0;
    for (const line of lines) {
      const id = line.split(/\s+/)[0];
      if (!id) continue;
      // minimize
      spawnSync('wmctrl', ['-i', '-r', id, '-b', 'add,hidden,below'], { encoding: 'utf8' });
      // also park far off-screen
      spawnSync('wmctrl', ['-i', '-r', id, '-e', '0,-32000,-32000,-1,-1'], { encoding: 'utf8' });
      n += 1;
    }
    return { ok: true, windows: n };
  } catch (e) {
    return { ok: false, reason: String(e.message || e) };
  }
}

function writeDaemonState(state) {
  ensureDirOnly();
  fs.mkdirSync(STORE_DIR, { recursive: true });
  fs.writeFileSync(
    DAEMON_STATE,
    JSON.stringify({ ...state, updated_at: new Date().toISOString() }, null, 2),
  );
}

function readDaemonState() {
  try {
    return JSON.parse(fs.readFileSync(DAEMON_STATE, 'utf8'));
  } catch {
    return null;
  }
}

function cmdDaemon(sub, g) {
  const action = sub || 'status';

  if (action === 'start' || action === 'restart') {
    // Prefer systemd user unit (lightweight, supervised). Fallback: opencli daemon.
    const hasSystemd =
      spawnSync('systemctl', ['--user', 'is-system-running'], { encoding: 'utf8' }).status === 0 ||
      spawnSync('systemctl', ['--user', 'status'], { encoding: 'utf8' }).status === 0 ||
      fs.existsSync(path.join(os.homedir(), '.config/systemd/user/fb-opencli.service'));

    let via = 'opencli';
    if (hasSystemd) {
      spawnSync('systemctl', ['--user', 'daemon-reload'], { encoding: 'utf8' });
      const u = action === 'restart' ? 'restart' : 'start';
      const r = spawnSync('systemctl', ['--user', u, 'fb-opencli.service'], {
        encoding: 'utf8',
        timeout: 20000,
      });
      if (r.status === 0) {
        via = 'systemd';
        spawnSync('systemctl', ['--user', 'start', 'fb-hide.timer'], { encoding: 'utf8' });
      } else {
        spawnSync(OPENCLI, ['daemon', 'restart'], { encoding: 'utf8', timeout: 30000 });
      }
    } else {
      spawnSync(OPENCLI, ['daemon', 'restart'], { encoding: 'utf8', timeout: 30000 });
    }

    // Wait briefly for daemon port
    spawnSync('sleep', ['1']);

    // Lightweight policy: DO NOT spawn a second Chrome.
    // Reuse existing Chrome with OpenCLI extension. Optional: systemctl --user enable fb-chrome-lean
    const chromeRunning =
      spawnSync('pgrep', ['-f', 'google-chrome|chromium'], { encoding: 'utf8' }).status === 0;

    const hidden = hideChromeWindows();
    const doctor = spawnSync(OPENCLI, ['doctor'], { encoding: 'utf8', timeout: 60000 });
    const who = opencli(['facebook', 'whoami', '-f', 'json'], {
      json: true,
      timeout: 90000,
      windowMode: 'background',
    });
    const me = who.status === 0 ? tryParseJson(who.stdout) : null;
    const state = {
      running: true,
      via,
      window: 'background',
      invisible: true,
      doctor_ok: doctor.status === 0,
      authenticated: Boolean(me?.logged_in || me?.user_id),
      user_id: me?.user_id || null,
      chrome_running: chromeRunning,
      chrome_hidden: hidden,
      lightweight: true,
    };
    writeDaemonState(state);

    if (g.json) {
      console.log(JSON.stringify(state, null, 2));
    } else {
      console.log(`fb daemon ${action === 'restart' ? 'restarted' : 'started'} via ${via}`);
      console.log(`  window:    background (invisible)`);
      console.log(`  opencli:   ${state.doctor_ok ? 'ok' : 'FAIL'} (~60–80MB node bridge)`);
      console.log(`  auth:      ${state.authenticated ? 'yes' : 'no — run: fb auth'}`);
      console.log(
        `  chrome:    ${chromeRunning ? (hidden.ok ? `running, hidden (${hidden.windows})` : 'running') : 'not running — open Chrome once or: fb-service enable-chrome'}`,
      );
      console.log(`  store:     ${STORE_DIR}`);
      console.log(`  manage:    fb-service status | systemctl --user status fb-opencli`);
      if (!state.authenticated) {
        console.log('\nFirst-time login (visible once):  fb auth');
      }
    }
    process.exit(state.doctor_ok ? 0 : 1);
  }

  if (action === 'stop') {
    spawnSync('systemctl', ['--user', 'stop', 'fb-opencli.service'], { encoding: 'utf8' });
    spawnSync(OPENCLI, ['daemon', 'stop'], { encoding: 'utf8', timeout: 15000 });
    writeDaemonState({ running: false, window: 'background', invisible: true });
    if (g.json) console.log(JSON.stringify({ running: false }, null, 2));
    else console.log('fb daemon stopped (Chrome left alone — lightweight)');
    process.exit(0);
  }

  if (action === 'install') {
    const r = spawnSync(path.join(os.homedir(), 'bin/fb-service'), ['install'], {
      encoding: 'utf8',
      timeout: 60000,
    });
    process.stdout.write(r.stdout || '');
    process.stderr.write(r.stderr || '');
    process.exit(r.status || 0);
  }

  if (action === 'status' || action === 'check') {
    const st = readDaemonState() || {};
    const doctor = spawnSync(OPENCLI, ['doctor'], { encoding: 'utf8', timeout: 30000 });
    const who = opencli(['facebook', 'whoami', '-f', 'json'], {
      json: true,
      timeout: 60000,
      windowMode: 'background',
    });
    const me = who.status === 0 ? tryParseJson(who.stdout) : null;
    const status = {
      version: VERSION,
      window_default: DEFAULT_WINDOW,
      invisible: DEFAULT_WINDOW === 'background',
      daemon_state: st,
      doctor_ok: doctor.status === 0,
      doctor_out: (doctor.stdout || '').trim().split('\n').slice(0, 8),
      authenticated: Boolean(me?.logged_in || me?.user_id),
      account: me,
      store: STORE_DIR,
    };
    if (g.json) console.log(JSON.stringify(status, null, 2));
    else {
      console.log(`fb daemon status (v${VERSION})`);
      console.log(`  default window: ${DEFAULT_WINDOW} ${DEFAULT_WINDOW === 'background' ? '(invisible)' : '(VISIBLE)'}`);
      console.log(`  doctor:         ${status.doctor_ok ? 'ok' : 'FAIL'}`);
      console.log(`  authenticated:  ${status.authenticated ? 'yes' : 'no'}`);
      if (me?.user_id) console.log(`  user_id:        ${me.user_id}`);
      console.log(`  store:          ${STORE_DIR}`);
    }
    process.exit(status.doctor_ok && status.authenticated ? 0 : 1);
  }

  if (action === 'hide') {
    const hidden = hideChromeWindows();
    if (g.json) console.log(JSON.stringify(hidden, null, 2));
    else if (hidden.ok) console.log(`hid ${hidden.windows} Chrome window(s)`);
    else console.log(`hide failed: ${hidden.reason}`);
    process.exit(hidden.ok ? 0 : 1);
  }

  console.error('Usage: fb daemon install|start|stop|status|restart|hide');
  process.exit(2);
}

function printRaw(result, { json }) {
  if (result.stdout) process.stdout.write(result.stdout.endsWith('\n') ? result.stdout : result.stdout + '\n');
  if (result.stderr && result.status !== 0) {
    process.stderr.write(result.stderr);
  }
  if (result.error) {
    console.error(String(result.error.message || result.error));
  }
  process.exit(result.status === 0 ? 0 : result.status || 1);
}

function tryParseJson(text) {
  const t = text.trim();
  if (!t) return null;
  try {
    return JSON.parse(t);
  } catch {
    // opencli sometimes prints YAML-ish or multi docs; try first JSON object/array
    const startObj = t.indexOf('{');
    const startArr = t.indexOf('[');
    let start = -1;
    if (startObj >= 0 && startArr >= 0) start = Math.min(startObj, startArr);
    else start = Math.max(startObj, startArr);
    if (start < 0) return null;
    try {
      return JSON.parse(t.slice(start));
    } catch {
      return null;
    }
  }
}

function asRows(parsed) {
  if (parsed == null) return [];
  if (Array.isArray(parsed)) return parsed;
  if (typeof parsed === 'object') {
    // single whoami object or { data: [] }
    if (Array.isArray(parsed.data)) return parsed.data;
    return [parsed];
  }
  return [];
}

function printTable(rows) {
  if (!rows.length) {
    console.log('(empty)');
    return;
  }
  const keys = Object.keys(rows[0]);
  const widths = keys.map((k) =>
    Math.min(
      60,
      Math.max(k.length, ...rows.map((r) => String(r[k] ?? '').length)),
    ),
  );
  const line = (vals) =>
    vals.map((v, i) => String(v ?? '').padEnd(widths[i]).slice(0, widths[i])).join('  ');
  console.log(line(keys));
  console.log(widths.map((w) => '-'.repeat(w)).join('  '));
  for (const row of rows) {
    console.log(line(keys.map((k) => row[k])));
  }
  console.log(`\n${rows.length} row(s)`);
}

function emit(rows, { json, plain }) {
  if (json) {
    console.log(JSON.stringify(rows.length === 1 && !Array.isArray(rows) ? rows[0] : rows, null, 2));
    return;
  }
  if (plain) {
    for (const row of rows) {
      if (typeof row === 'object') console.log(Object.values(row).join('\t'));
      else console.log(row);
    }
    return;
  }
  printTable(rows);
}

function usage() {
  console.log(`fb ${VERSION} — Facebook/Messenger CLI (opencli-backed)

Usage:
  fb <command> [args] [options]

Daemon / services (lightweight):
  fb daemon install        Install systemd user units (opencli + hide timer)
  fb daemon start|restart  Prefer systemd fb-opencli.service
  fb daemon stop           Stop bridge daemon
  fb daemon status         Health + auth
  fb daemon hide           Re-hide Chrome off-screen
  fb-service status        systemctl view of units

Auth / health:
  fb auth | login          Visible login once (foreground), then stay invisible
  fb whoami                Show logged-in account
  fb status                Auth + store + last sync summary
  fb doctor                opencli doctor + Facebook session probe
  fb check                 Alias for status

Sync (like wacli sync — snapshot into local SQLite):
  fb sync [--limit N]      Pull notifications, groups, chats into ~/.local/state/fb/fb.db

Read (live via Chrome session):
  fb home | feed [--limit N]
  fb notifications [--limit N]
  fb groups [--limit N]
  fb friends [--limit N]
  fb search <query>                 # top results (mixed)
  fb posts <query> [--limit N]      # public post search (author + summary + url)
  fb post <url|fbid>                # deep-read one public post/photo/reel
  fb research <query> [--limit N]   # posts search + deep-read top results
  fb profile <username>
  fb chats | messages [--limit N]
  fb thread <id|url> [--limit N]
  fb media|pull <thread|post-url> [--out DIR] [--limit N] [--keep]
      Unified temp-download for Messenger threads OR public posts
      (photos/videos/pdf/files/links → ~/.local/state/fb/tmp/<id>)
  fb open <path>           Open a downloaded file with the system viewer
  fb keep <path|thread>    Move tmp file(s) to ~/.local/state/fb/keep/
  fb purge [thread|all]    Delete disposable tmp downloads
  fb events [--limit N]
  fb memories [--limit N]
  fb marketplace listings|inbox [--limit N]

  thread columns include: kind, links, media_urls, attachment_urls
  (shared FB posts, external links, photo CDN URLs, messenger_media links)

Write:
  fb send --to <thread_id|url> --message "..."
  fb add-friend <username>
  fb join-group <group>

Local store queries (offline after sync):
  fb db notifications [--limit N]
  fb db chats [--limit N]
  fb db groups [--limit N]
  fb db search <query>

Options:
  --json, -j          JSON output
  --plain             TSV-ish plain output
  --limit, -n <N>     Limit rows
  --window <mode>     foreground | background (default: background / invisible)
  --store <dir>       Override store directory
  -h, --help          Help
  -V, --version       Version

Environment:
  OPENCLI_BIN         Path to opencli
  FB_STORE_DIR        Store directory (default: ~/.local/state/fb)
  FB_WINDOW           background (default) | foreground
  OPENCLI_WINDOW      same (opencli-native)

Notes:
  • Backend is Chrome + OpenCLI extension, but defaults to invisible (background) windows.
  • Run fb daemon start once per boot; fb auth once if not logged in (visible login).
  • Messenger + posts adapters live in ~/.opencli/clis/facebook/.
`);
}

function effectiveWindow(g, { force } = {}) {
  if (force) return force;
  if (g.window === 'foreground' || g.window === 'background') return g.window;
  return DEFAULT_WINDOW;
}

function facebookArgs(sub, extra = [], g, windowMode) {
  const args = ['facebook', sub, ...extra];
  if (g.limit != null) args.push('--limit', String(g.limit));
  const mode = windowMode || effectiveWindow(g);
  // always set explicitly
  args.push('--window', mode);
  return args;
}

function runFacebook(sub, extra, g, opts = {}) {
  const mode = effectiveWindow(g, opts);
  const result = opencli(facebookArgs(sub, extra, g, mode), {
    json: true,
    windowMode: mode,
    timeout: opts.timeout || 180000,
  });
  const parsed = result.status === 0 ? tryParseJson(result.stdout) : null;
  if (parsed) {
    emit(asRows(parsed), g);
    process.exit(0);
  }
  printRaw(result, g);
}

function setMeta(key, value) {
  const ts = nowIso();
  runSql(
    `INSERT INTO meta(key,value,updated_at) VALUES('${sqlEscape(key)}','${sqlEscape(value)}','${ts}')
     ON CONFLICT(key) DO UPDATE SET value=excluded.value, updated_at=excluded.updated_at;`,
  );
}

function getMeta(key) {
  const out = runSql(`SELECT value FROM meta WHERE key='${sqlEscape(key)}' LIMIT 1;`).trim();
  return out || null;
}

function cmdSync(g) {
  ensureStore();
  const limit = g.limit || '30';
  const report = { ok: true, notifications: 0, groups: 0, chats: 0, errors: [] };
  const ts = nowIso();

  function pull(name, opencliSub, mapRow) {
    const r = opencli(['facebook', opencliSub, '--limit', String(limit), '-f', 'json'], {
      json: true,
      timeout: 180000,
    });
    if (r.status !== 0) {
      report.errors.push({ name, error: (r.stderr || r.stdout || 'failed').trim().slice(0, 300) });
      return [];
    }
    const rows = asRows(tryParseJson(r.stdout));
    return rows;
  }

  // notifications
  try {
    const rows = pull('notifications', 'notifications');
    for (const row of rows) {
      const id = row.notif_id || row.Notif_id || row.url || `${row.text}-${row.time}`;
      runSql(
        `INSERT INTO notifications(notif_id,unread,text,time,url,notif_type,synced_at)
         VALUES('${sqlEscape(id)}',${row.unread ? 1 : 0},'${sqlEscape(row.text)}','${sqlEscape(row.time)}','${sqlEscape(row.url)}','${sqlEscape(row.notif_type || row.Notif_type)}','${ts}')
         ON CONFLICT(notif_id) DO UPDATE SET
           unread=excluded.unread, text=excluded.text, time=excluded.time,
           url=excluded.url, notif_type=excluded.notif_type, synced_at=excluded.synced_at;`,
      );
    }
    report.notifications = rows.length;
  } catch (e) {
    report.errors.push({ name: 'notifications', error: String(e.message || e) });
  }

  // groups
  try {
    const rows = pull('groups', 'groups');
    for (const row of rows) {
      const url = row.url || row.Url || row.name;
      runSql(
        `INSERT INTO groups(url,name,last_post,synced_at)
         VALUES('${sqlEscape(url)}','${sqlEscape(row.name)}','${sqlEscape(row.last_post || row.Last_post || '')}','${ts}')
         ON CONFLICT(url) DO UPDATE SET name=excluded.name, last_post=excluded.last_post, synced_at=excluded.synced_at;`,
      );
    }
    report.groups = rows.length;
  } catch (e) {
    report.errors.push({ name: 'groups', error: String(e.message || e) });
  }

  // chats / messages inbox
  try {
    const rows = pull('chats', 'messages');
    for (const row of rows) {
      const tid = row.thread_id || row.threadId;
      if (!tid) continue;
      runSql(
        `INSERT INTO chats(thread_id,name,snippet,time,unread,url,synced_at)
         VALUES('${sqlEscape(tid)}','${sqlEscape(row.name)}','${sqlEscape(row.snippet)}','${sqlEscape(row.time)}',${row.unread ? 1 : 0},'${sqlEscape(row.url)}','${ts}')
         ON CONFLICT(thread_id) DO UPDATE SET
           name=excluded.name, snippet=excluded.snippet, time=excluded.time,
           unread=excluded.unread, url=excluded.url, synced_at=excluded.synced_at;`,
      );
    }
    report.chats = rows.length;
  } catch (e) {
    report.errors.push({ name: 'chats', error: String(e.message || e) });
  }

  // whoami cache
  try {
    const r = opencli(['facebook', 'whoami', '-f', 'json'], { json: true });
    if (r.status === 0) {
      const me = tryParseJson(r.stdout);
      if (me) setMeta('whoami', JSON.stringify(me));
    }
  } catch {
    /* ignore */
  }

  setMeta('last_sync', ts);
  setMeta('last_sync_report', JSON.stringify(report));
  report.ok = report.errors.length === 0;
  report.store = DB_PATH;
  report.synced_at = ts;

  if (g.json) console.log(JSON.stringify(report, null, 2));
  else {
    console.log(`fb sync ${report.ok ? 'OK' : 'PARTIAL'}`);
    console.log(`  notifications: ${report.notifications}`);
    console.log(`  groups:        ${report.groups}`);
    console.log(`  chats:         ${report.chats}`);
    console.log(`  store:         ${DB_PATH}`);
    if (report.errors.length) {
      console.log('  errors:');
      for (const e of report.errors) console.log(`    - ${e.name}: ${e.error}`);
    }
  }
  process.exit(report.ok ? 0 : 1);
}

function cmdStatus(g) {
  ensureStore();
  const doctor = opencli(['doctor'], { json: false, timeout: 60000 });
  const who = opencli(['facebook', 'whoami', '-f', 'json'], { json: true, timeout: 120000 });
  const me = who.status === 0 ? tryParseJson(who.stdout) : null;
  const lastSync = getMeta('last_sync');
  const counts = {
    notifications: Number(runSql('SELECT COUNT(*) FROM notifications;').trim() || 0),
    groups: Number(runSql('SELECT COUNT(*) FROM groups;').trim() || 0),
    chats: Number(runSql('SELECT COUNT(*) FROM chats;').trim() || 0),
  };
  const status = {
    version: VERSION,
    opencli: OPENCLI,
    store: DB_PATH,
    authenticated: Boolean(me?.logged_in || me?.user_id),
    account: me,
    last_sync: lastSync,
    local_counts: counts,
    doctor_ok: doctor.status === 0,
  };
  if (g.json) {
    console.log(JSON.stringify(status, null, 2));
  } else {
    console.log(`fb ${VERSION}`);
    console.log(`  opencli:   ${OPENCLI}`);
    console.log(`  store:     ${DB_PATH}`);
    console.log(`  doctor:    ${status.doctor_ok ? 'ok' : 'FAIL'}`);
    console.log(
      `  auth:      ${status.authenticated ? 'yes' : 'no'}${me?.user_id ? ` (user_id=${me.user_id})` : ''}`,
    );
    console.log(`  last_sync: ${lastSync || '(never)'}`);
    console.log(
      `  local:     notifs=${counts.notifications} groups=${counts.groups} chats=${counts.chats}`,
    );
    if (!status.authenticated) {
      console.log('\nRun: fb auth');
    }
  }
  process.exit(status.authenticated && status.doctor_ok ? 0 : 1);
}

function cmdDoctor(g) {
  const r = opencli(['doctor'], { json: false });
  process.stdout.write(r.stdout || '');
  process.stderr.write(r.stderr || '');
  console.log('\n--- Facebook session ---');
  const who = opencli(['facebook', 'whoami', '-f', 'json'], { json: true });
  if (who.status === 0) {
    console.log(who.stdout.trim());
  } else {
    console.log('Not authenticated or whoami failed.');
    console.log((who.stderr || who.stdout || '').trim().slice(0, 400));
  }
  process.exit(r.status === 0 && who.status === 0 ? 0 : 1);
}

function cmdDb(sub, queryArgs, g) {
  ensureStore();
  const limit = Number(g.limit || 20);
  let sql;
  if (sub === 'notifications') {
    sql = `SELECT notif_id, unread, substr(text,1,120) AS text, time, notif_type FROM notifications ORDER BY synced_at DESC LIMIT ${limit};`;
  } else if (sub === 'chats') {
    sql = `SELECT thread_id, name, substr(snippet,1,80) AS snippet, time, unread FROM chats ORDER BY synced_at DESC LIMIT ${limit};`;
  } else if (sub === 'groups') {
    sql = `SELECT name, last_post, url FROM groups ORDER BY synced_at DESC LIMIT ${limit};`;
  } else if (sub === 'search') {
    const q = queryArgs.join(' ').trim();
    if (!q) {
      console.error('Usage: fb db search <query>');
      process.exit(2);
    }
    sql = `SELECT 'notif' AS kind, text AS body, url AS ref FROM notifications WHERE text LIKE '%${sqlEscape(q)}%'
           UNION ALL
           SELECT 'chat', name || ': ' || snippet, url FROM chats WHERE name LIKE '%${sqlEscape(q)}%' OR snippet LIKE '%${sqlEscape(q)}%'
           UNION ALL
           SELECT 'group', name, url FROM groups WHERE name LIKE '%${sqlEscape(q)}%'
           LIMIT ${limit};`;
  } else {
    console.error('Usage: fb db notifications|chats|groups|search');
    process.exit(2);
  }
  // JSON mode via sqlite
  if (g.json) {
    const out = runSql(`.mode json\n${sql}`);
    console.log(out.trim() || '[]');
    process.exit(0);
  }
  const out = runSql(`.mode column\n.headers on\n${sql}`);
  process.stdout.write(out.endsWith('\n') ? out : out + '\n');
  process.exit(0);
}

function parseSendArgs(argv) {
  let to = null;
  let message = null;
  const rest = [];
  for (let i = 0; i < argv.length; i += 1) {
    const a = argv[i];
    if (a === '--to' || a === '-t') to = argv[++i];
    else if (a === '--message' || a === '-m') message = argv[++i];
    else rest.push(a);
  }
  // allow: fb send <to> <message...>
  if (!to && rest.length) to = rest.shift();
  if (!message && rest.length) message = rest.join(' ');
  return { to, message };
}

function main() {
  const g = parseGlobalArgs(process.argv.slice(2));
  if (g.version) {
    console.log(VERSION);
    process.exit(0);
  }
  if (g.help || g.rest.length === 0) {
    usage();
    process.exit(g.help ? 0 : 2);
  }

  const [cmd, ...args] = g.rest;

  switch (cmd) {
    case 'daemon':
      cmdDaemon(args[0], g);
      break;
    case 'auth':
    case 'login':
      // Login must be visible once so you can type password / 2FA / approve.
      console.error('fb auth: using visible browser for login (one-time). After success, backend stays invisible.');
      printRaw(
        opencli(['facebook', 'login', '--window', 'foreground'], {
          json: false,
          timeout: 600000,
          windowMode: 'foreground',
        }),
        g,
      );
      // re-hide after login attempt
      hideChromeWindows();
      break;
    case 'whoami':
      runFacebook('whoami', [], g);
      break;
    case 'status':
    case 'check':
      cmdStatus(g);
      break;
    case 'doctor':
      cmdDoctor(g);
      break;
    case 'sync':
      cmdSync(g);
      break;
    case 'home':
    case 'feed':
      runFacebook('feed', [], g);
      break;
    case 'notifications':
    case 'notifs':
      runFacebook('notifications', [], g);
      break;
    case 'groups':
      runFacebook('groups', [], g);
      break;
    case 'friends':
      runFacebook('friends', [], g);
      break;
    case 'search':
      if (!args[0]) {
        console.error('Usage: fb search <query>');
        process.exit(2);
      }
      runFacebook('search', [args.join(' ')], g);
      break;
    case 'posts':
    case 'search-posts':
      if (!args[0]) {
        console.error('Usage: fb posts <query>');
        process.exit(2);
      }
      runFacebook('search-posts', [args.join(' ')], g);
      break;
    case 'post':
    case 'read-post':
      if (!args[0]) {
        console.error('Usage: fb post <url|fbid>');
        process.exit(2);
      }
      runFacebook('post', [args[0]], g);
      break;
    case 'research': {
      if (!args[0]) {
        console.error('Usage: fb research <query> [--limit N]');
        process.exit(2);
      }
      const q = args.join(' ');
      const lim = Number(g.limit || 5);
      const search = opencli(
        ['facebook', 'search-posts', q, '--limit', String(lim), '-f', 'json'],
        { json: true, timeout: 180000, windowMode: effectiveWindow(g) },
      );
      if (search.status !== 0) {
        printRaw(search, g);
        break;
      }
      const hits = asRows(tryParseJson(search.stdout));
      const report = { query: q, count: hits.length, posts: [] };
      for (const hit of hits.slice(0, lim)) {
        const url = hit.url || hit.Url;
        const entry = {
          search: hit,
          detail: null,
          error: null,
        };
        if (url) {
          const deep = opencli(['facebook', 'post', url, '-f', 'json'], {
            json: true,
            timeout: 120000,
            windowMode: effectiveWindow(g),
          });
          if (deep.status === 0) {
            const rows = asRows(tryParseJson(deep.stdout));
            entry.detail = rows[0] || null;
          } else {
            entry.error = (deep.stderr || deep.stdout || 'deep-read failed').trim().slice(0, 240);
          }
        } else {
          entry.error = 'no public url in search hit';
        }
        report.posts.push(entry);
      }
      if (g.json) {
        console.log(JSON.stringify(report, null, 2));
      } else {
        console.log(`fb research: ${q}`);
        console.log(`hits: ${report.count}\n`);
        report.posts.forEach((p, i) => {
          const s = p.search || {};
          const d = p.detail || {};
          console.log(`── ${i + 1}. ${d.author || s.author || '(unknown)'}  [${d.kind || s.kind || ''}]`);
          console.log(`url: ${d.url || s.url || ''}`);
          const body = d.text || s.summary || '';
          console.log(body.slice(0, 420) + (body.length > 420 ? '…' : ''));
          if (d.likes || d.loves || d.reactions) {
            console.log(
              `reactions: likes=${d.likes || '-'} loves=${d.loves || '-'} other=${d.reactions || '-'} comments=${d.comments_count || '-'}`,
            );
          }
          if (d.links) console.log(`links: ${String(d.links).slice(0, 200)}`);
          if (p.error) console.log(`note: ${p.error}`);
          console.log('');
        });
      }
      process.exit(0);
      break;
    }
    case 'profile':
      if (!args[0]) {
        console.error('Usage: fb profile <username>');
        process.exit(2);
      }
      runFacebook('profile', [args[0]], g);
      break;
    case 'chats':
    case 'messages':
    case 'inbox':
      runFacebook('messages', [], g);
      break;
    case 'thread':
    case 'read':
      if (!args[0]) {
        console.error('Usage: fb thread <thread_id|url>');
        process.exit(2);
      }
      runFacebook('thread', [args[0]], g);
      break;
    case 'media':
    case 'pull':
    case 'download-media':
    case 'media-download': {
      if (!args[0]) {
        console.error('Usage: fb pull <thread_id|url> [--out DIR] [--limit N] [--keep]');
        process.exit(2);
      }
      const mediaExtra = [args[0]];
      for (let i = 1; i < args.length; i += 1) {
        if (args[i] === '--out' && args[i + 1]) mediaExtra.push('--out', args[++i]);
        else if (args[i] === '--keep') mediaExtra.push('--keep', 'true');
        else if (args[i] === '--limit' && args[i + 1]) {
          // also set global limit for opencli
          g.limit = args[++i];
        }
      }
      runFacebook('media-download', mediaExtra, g);
      break;
    }
    case 'open': {
      const p = args[0];
      if (!p) {
        console.error('Usage: fb open <path>');
        process.exit(2);
      }
      const target = path.resolve(p);
      if (!fs.existsSync(target)) {
        console.error(`Not found: ${target}`);
        process.exit(1);
      }
      // Fully detach GUI viewer so the CLI never hangs on xdg-open
      const bin =
        process.platform === 'darwin' ? 'open' : process.platform === 'win32' ? 'cmd' : 'xdg-open';
      const argv =
        process.platform === 'win32' ? ['/c', 'start', '', target] : [target];
      const child = spawn(bin, argv, {
        detached: true,
        stdio: 'ignore',
      });
      child.unref();
      console.log(`opened: ${target}`);
      process.exit(0);
      break;
    }
    case 'keep': {
      ensureStore();
      const src = args[0];
      if (!src) {
        console.error('Usage: fb keep <file-or-thread-id>');
        process.exit(2);
      }
      const store = process.env.FB_STORE_DIR || path.join(os.homedir(), '.local/state/fb');
      const keepRoot = path.join(store, 'keep');
      fs.mkdirSync(keepRoot, { recursive: true });
      let fromPath = path.resolve(src);
      if (!fs.existsSync(fromPath)) {
        // treat as thread id tmp folder
        fromPath = path.join(store, 'tmp', src);
      }
      if (!fs.existsSync(fromPath)) {
        console.error(`Not found: ${src}`);
        process.exit(1);
      }
      const st = fs.statSync(fromPath);
      if (st.isDirectory()) {
        const dest = path.join(keepRoot, path.basename(fromPath));
        fs.mkdirSync(dest, { recursive: true });
        for (const name of fs.readdirSync(fromPath)) {
          if (name === 'manifest.json') continue;
          fs.renameSync(path.join(fromPath, name), path.join(dest, name));
        }
        // copy manifest if present
        const man = path.join(fromPath, 'manifest.json');
        if (fs.existsSync(man)) fs.copyFileSync(man, path.join(dest, 'manifest.json'));
        console.log(`kept directory → ${dest}`);
      } else {
        const dest = path.join(keepRoot, path.basename(fromPath));
        fs.renameSync(fromPath, dest);
        console.log(`kept → ${dest}`);
      }
      process.exit(0);
      break;
    }
    case 'purge': {
      const store = process.env.FB_STORE_DIR || path.join(os.homedir(), '.local/state/fb');
      const tmpRoot = path.join(store, 'tmp');
      const target = args[0] || 'all';
      if (!fs.existsSync(tmpRoot)) {
        console.log('nothing to purge');
        process.exit(0);
      }
      if (target === 'all') {
        fs.rmSync(tmpRoot, { recursive: true, force: true });
        fs.mkdirSync(tmpRoot, { recursive: true });
        console.log(`purged all temp media under ${tmpRoot}`);
      } else {
        const dir = path.join(tmpRoot, target);
        if (!fs.existsSync(dir)) {
          console.error(`No tmp folder for thread: ${target}`);
          process.exit(1);
        }
        fs.rmSync(dir, { recursive: true, force: true });
        console.log(`purged ${dir}`);
      }
      process.exit(0);
      break;
    }
    case 'send': {
      const { to, message } = parseSendArgs(args);
      if (!to || !message) {
        console.error('Usage: fb send --to <thread_id|url> --message "text"');
        process.exit(2);
      }
      runFacebook('send-message', ['--to', to, '--message', message], g);
      break;
    }
    case 'add-friend':
      if (!args[0]) {
        console.error('Usage: fb add-friend <username>');
        process.exit(2);
      }
      runFacebook('add-friend', [args[0]], g);
      break;
    case 'join-group':
      if (!args[0]) {
        console.error('Usage: fb join-group <group>');
        process.exit(2);
      }
      runFacebook('join-group', [args[0]], g);
      break;
    case 'events':
      runFacebook('events', [], g);
      break;
    case 'memories':
      runFacebook('memories', [], g);
      break;
    case 'marketplace': {
      const sub = args[0];
      if (sub === 'listings' || sub === 'list') runFacebook('marketplace-listings', args.slice(1), g);
      else if (sub === 'inbox') runFacebook('marketplace-inbox', args.slice(1), g);
      else {
        console.error('Usage: fb marketplace listings|inbox');
        process.exit(2);
      }
      break;
    }
    case 'db':
      cmdDb(args[0], args.slice(1), g);
      break;
    case 'help':
      usage();
      process.exit(0);
      break;
    default:
      console.error(`Unknown command: ${cmd}\n`);
      usage();
      process.exit(2);
  }
}

try {
  main();
} catch (err) {
  console.error(`fb error: ${err instanceof Error ? err.message : err}`);
  process.exit(1);
}
