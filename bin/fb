#!/usr/bin/env node
/**
 * fb 0.7.0 — Facebook/Messenger CLI, wacli/bird-shaped, lightweight.
 *
 * v0.7.0 changes:
 *   - Default transport is the opencli-managed Chrome on :9222 (or whichever
 *     CDP port is reachable). No fb-managed Chrome, no wmctrl/xdotool/hide
 *     dance, no systemd timer. The user can close the Chrome window;
 *     opencli keeps the browser process alive in the background.
 *   - Optional: `fb-headless start` launches a dedicated headless Chrome on
 *     a separate profile (port 9223) for users who want zero visible UI.
 *     Set FB_CHROME_ENDPOINT=http://127.0.0.1:9223 to opt in.
 *   - All other v0.6.0 surface preserved: FTS5 store, accounts, completion,
 *     --json/--events/--read-only/--account/--store/--timeout/--no-color,
 *     per-subcommand help, lock file, deterministic exit codes.
 *
 * Scope is unchanged: this is a shell over opencli + a local SQLite store.
 */

import { spawn, spawnSync } from 'node:child_process';
import fs from 'node:fs';
import os from 'node:os';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import readline from 'node:readline';

const VERSION = '0.7.0';
const PROGRAM = 'fb';

const XDG_STATE = process.env.XDG_STATE_HOME || path.join(os.homedir(), '.local/state');
const XDG_CONFIG = process.env.XDG_CONFIG_HOME || path.join(os.homedir(), '.config');
const DEFAULT_STORE = path.join(XDG_STATE, 'fb');
const STORE_DIR = process.env.FB_STORE_DIR || DEFAULT_STORE;
const DB_PATH = path.join(STORE_DIR, 'fb.db');
const LOCK_PATH = path.join(STORE_DIR, 'fb.lock');
const DAEMON_STATE = path.join(STORE_DIR, 'daemon.json');
const CACHE_DIR = path.join(STORE_DIR, 'cache');
const TMP_DIR = path.join(STORE_DIR, 'tmp');
const KEEP_DIR = path.join(STORE_DIR, 'keep');
const CONFIG_PATH = process.env.FB_CONFIG || path.join(XDG_CONFIG, 'fb', 'config.json5');

const EXIT = { OK: 0, USAGE: 2, NOT_AUTHED: 3, NOT_FOUND: 4, READ_ONLY: 5, LOCKED: 6, OPENCLI_FAIL: 7, INTERNAL: 1 };

const nowIso = () => new Date().toISOString();
const sleepMs = (ms) => spawnSync('sleep', [String(ms / 1000)]);
const which = (bin) => {
  const r = spawnSync('which', [bin], { encoding: 'utf8' });
  return r.status === 0 ? r.stdout.trim() : null;
};
const fileExists = (p) => { try { fs.accessSync(p); return true; } catch { return false; } };
const die = (msg, code = EXIT.USAGE, { json } = {}) => {
  if (json) console.log(JSON.stringify({ ok: false, error: msg, exit: code, version: VERSION }, null, 2));
  else console.error(`fb: ${msg}`);
  process.exit(code);
};

// ─── config (JSON5-lite) ────────────────────────────────────────────────────
function parseJson5Lite(src) {
  let out = ''; let i = 0; let inStr = null;
  while (i < src.length) {
    const c = src[i]; const n = src[i + 1];
    if (inStr) {
      out += c;
      if (c === '\\' && i + 1 < src.length) { out += n; i += 2; continue; }
      if (c === inStr) inStr = null;
      i += 1; continue;
    }
    if (c === '"' || c === "'") { inStr = c; out += c; i += 1; continue; }
    if (c === '/' && n === '/') { while (i < src.length && src[i] !== '\n') i += 1; continue; }
    if (c === '/' && n === '*') { i += 2; while (i < src.length && !(src[i] === '*' && src[i+1] === '/')) i += 1; i += 2; continue; }
    out += c; i += 1;
  }
  out = out.replace(/([{,]\s*)([A-Za-z_$][A-Za-z0-9_$]*)(\s*:)/g, '$1"$2"$3');
  out = out.replace(/,(\s*[}\]])/g, '$1');
  return JSON.parse(out);
}
function loadConfig() {
  try { return parseJson5Lite(fs.readFileSync(CONFIG_PATH, 'utf8')); } catch { return {}; }
}
const CFG = loadConfig();
function cfgStore() { return process.env.FB_STORE_DIR || CFG.store || DEFAULT_STORE; }
function cfgAccount() { return process.env.FB_ACCOUNT || CFG.account || 'default'; }

// ─── global flag parsing ────────────────────────────────────────────────────
function parseArgs(argv) {
  const out = {
    json: false, events: false, readOnly: false, plain: false, full: false,
    noColor: !!CFG.noColor || !!process.env.NO_COLOR || !!process.env.FB_NO_COLOR,
    account: null, store: null, timeout: null, limit: null, window: null,
    help: false, version: false, rest: [],
  };
  const a = [...argv];
  const eat = () => a.shift();
  while (a.length) {
    const tok = eat();
    switch (tok) {
      case '--json': case '-j': out.json = true; break;
      case '--events': out.events = true; break;
      case '--read-only': out.readOnly = true; break;
      case '--plain': out.plain = true; break;
      case '--full': out.full = true; break;
      case '--no-color': out.noColor = true; break;
      case '--help': case '-h': out.help = true; break;
      case '--version': case '-V': out.version = true; break;
      case '--account': out.account = eat() ?? null; break;
      case '--store': out.store = eat() ?? null; if (out.store) process.env.FB_STORE_DIR = out.store; break;
      case '--timeout': out.timeout = eat() ?? null; break;
      case '--limit': case '-n': out.limit = eat() ?? null; break;
      case '--window': out.window = eat() ?? null; break;
      default: out.rest.push(tok);
    }
  }
  if (out.readOnly || process.env.FB_READONLY === '1' || CFG.readOnly) out.readOnly = true;
  if (out.account == null) out.account = cfgAccount();
  return out;
}

// ─── opencli daemon + Chrome CDP discovery ─────────────────────────────────
// opencli has two services:
//   1. Daemon (port 19825) — Node bridge that the CLI calls
//   2. Chrome (port 9222 by default, 9223 for headless) — actual browser
// The Browser Bridge extension lives inside Chrome and connects to the daemon.
// For the headless path, we manage a separate Chrome on :9223 with its own
// profile (fb-headless), so it can run alongside the user's normal Chrome
// without SingletonLock conflicts.
const HEADLESS_CDP = 'http://127.0.0.1:9223';
const VISIBLE_CDP = 'http://127.0.0.1:9222';
const DAEMON_URL_DEFAULT = 'http://127.0.0.1:19825';

function cdpProbe(url) {
  try {
    const r = spawnSync('curl', ['-s', '--max-time', '1', '-o', '/dev/null', '-w', '%{http_code}', `${url}/json/version`], { encoding: 'utf8' });
    return r.stdout === '200';
  } catch { return false; }
}
function chromeCheck() {
  // User can override with FB_CHROME_ENDPOINT
  if (process.env.FB_CHROME_ENDPOINT) {
    const url = process.env.FB_CHROME_ENDPOINT;
    if (cdpProbe(url)) return { ok: true, url, headless: url.includes(':9223') };
    return { ok: false, reason: `FB_CHROME_ENDPOINT=${url} not reachable` };
  }
  // Prefer the headless Chrome on :9223 (it's the default path now)
  if (cdpProbe(HEADLESS_CDP)) return { ok: true, url: HEADLESS_CDP, headless: true };
  // Fall back to the user's visible Chrome on :9222
  if (cdpProbe(VISIBLE_CDP)) return { ok: true, url: VISIBLE_CDP, headless: false };
  return { ok: false, reason: 'no Chrome CDP reachable on :9222 or :9223 (run: fb-headless start)' };
}
function chromeStr() {
  const r = chromeCheck();
  if (r.ok) return `${r.url} (${r.headless ? 'headless' : 'visible'})`;
  return `NOT FOUND — ${r.reason}`;
}

// Ensure the headless Chrome is running. Called by the opencli wrapper and by
// `fb` commands that need a browser. Returns the CDP URL to use.
function ensureChrome({ autoStart = true } = {}) {
  const c = chromeCheck();
  if (c.ok) return c;
  if (!autoStart) return null;
  if (process.env.FB_NO_AUTOSTART) return null;
  // Try to start the headless Chrome
  if (!which('fb-headless')) return null;
  emitEvent('chrome.autostart', {});
  const r = spawnSync('fb-headless', ['start'], { encoding: 'utf8', timeout: 60000 });
  if (r.status !== 0) return null;
  // Re-probe
  const c2 = chromeCheck();
  return c2.ok ? c2 : null;
}

function discoverOpencliDaemon() {
  const ep = process.env.OPENCLI_DAEMON_URL || DAEMON_URL_DEFAULT;
  try {
    const r = spawnSync('curl', ['-s', '--max-time', '1', '-H', 'X-OpenCLI: 1', `${ep}/status`], { encoding: 'utf8' });
    if (r.status === 0 && r.stdout && r.stdout.includes('"ok":true')) return ep;
  } catch { /* */ }
  return null;
}
function daemonHealth() {
  const ep = discoverOpencliDaemon();
  if (!ep) return null;
  try {
    const r = spawnSync('curl', ['-s', '--max-time', '2', '-H', 'X-OpenCLI: 1', `${ep}/status`], { encoding: 'utf8' });
    if (r.status !== 0 || !r.stdout) return null;
    return JSON.parse(r.stdout);
  } catch { return null; }
}
function ensureOpencliDaemon({ autoStart = true } = {}) {
  let ep = discoverOpencliDaemon();
  if (ep) return ep;
  if (!autoStart) return null;
  if (process.env.FB_NO_AUTOSTART) return null;
  // Try to start the opencli daemon
  emitEvent('daemon.autostart', {});
  // opencli has no 'daemon start' — 'restart' brings it up if not running
  spawnSync(OPENCLI, ['daemon', 'restart'], { encoding: 'utf8', timeout: 30000 });
  sleepMs(1500);
  return discoverOpencliDaemon();
}

// Composite readiness: both daemon + chrome + extension connected
function bridgeCheck({ autoStart = true } = {}) {
  // 1. Ensure opencli daemon
  const dep = ensureOpencliDaemon({ autoStart });
  if (!dep) return { ok: false, reason: 'opencli daemon not reachable on 19825 (tried to start)', url: null };
  // 2. Ensure Chrome
  const cc = ensureChrome({ autoStart });
  if (!cc) return { ok: false, reason: 'no Chrome reachable (headless or visible) — tried fb-headless start', url: dep };
  // 3. Check extension connection
  const h = daemonHealth();
  if (!h) return { ok: false, reason: 'opencli daemon responded but status unparseable', url: dep, chrome: cc };
  if (!h.extensionConnected) {
    return { ok: false, reason: 'Browser Bridge extension not connected to opencli daemon (open Chrome with the extension loaded)', url: dep, chrome: cc, health: h };
  }
  return { ok: true, url: dep, chrome: cc, health: h };
}
function bridgeStr() {
  const r = bridgeCheck();
  if (r.ok) return `daemon=${r.url}  chrome=${r.chrome.url} (${r.chrome.headless ? 'headless' : 'visible'})`;
  let s = `NOT READY — ${r.reason}`;
  if (r.url) s += `  (daemon at ${r.url})`;
  if (r.chrome) s += `  (chrome at ${r.chrome.url})`;
  return s;
}

// Legacy alias: daemonCheck → bridgeCheck so existing call sites keep working
function daemonCheck() { return bridgeCheck({ autoStart: false }); }
function daemonStr() { return bridgeStr(); }

// ─── NDJSON events ──────────────────────────────────────────────────────────
let _eventsOn = false;
function emitEvent(type, data = {}) {
  if (!_eventsOn) return;
  const evt = { t: nowIso(), event: type, ...data };
  try { process.stderr.write(JSON.stringify(evt) + '\n'); } catch { /* */ }
}

// ─── opencli wrapper ────────────────────────────────────────────────────────
function whichOpencli() {
  const cands = [
    process.env.OPENCLI_BIN,
    path.join(os.homedir(), '.npm-global/bin/opencli'),
    '/usr/local/bin/opencli',
    'opencli',
  ].filter(Boolean);
  for (const c of cands) {
    if (c === 'opencli') return c;
    try { fs.accessSync(c, fs.constants.X_OK); return c; } catch { /* next */ }
  }
  return 'opencli';
}
const OPENCLI = whichOpencli();

function opencli(args, opts = {}) {
  const { json = true, timeout = 180000, windowMode } = opts;
  const cmdArgs = [...args];
  if (json && !cmdArgs.includes('-f') && !cmdArgs.includes('--format')) cmdArgs.push('-f', 'json');
  const hasWindow = cmdArgs.includes('--window');
  const mode = windowMode || 'background';
  const isBrowserCmd = cmdArgs[0] === 'facebook' || cmdArgs[0] === 'browser';
  if (!hasWindow && (mode === 'background' || mode === 'foreground') && isBrowserCmd) {
    cmdArgs.push('--window', mode);
  }
  if (isBrowserCmd && !cmdArgs.includes('--site-session')) cmdArgs.push('--site-session', 'persistent');
  if (isBrowserCmd && !cmdArgs.includes('--keep-tab') && mode === 'background') {
    cmdArgs.push('--keep-tab', 'false');
  }
  // Make sure the full bridge is ready (auto-starts daemon + headless Chrome if needed).
  // Then point opencli at the Chrome CDP endpoint (NOT the daemon URL — those are different).
  const bridge = bridgeCheck({ autoStart: true });
  const env = { ...process.env };
  if (bridge.ok && bridge.chrome) {
    env.OPENCLI_CDP_ENDPOINT = bridge.chrome.url;
  } else if (!bridge.ok) {
    emitEvent('opencli.skip', { reason: bridge.reason });
  }
  env.OPENCLI_WINDOW = mode;

  emitEvent('opencli.start', { sub: `${cmdArgs[0]}:${cmdArgs[1] || ''}`, mode, timeout, cdp: env.OPENCLI_CDP_ENDPOINT || 'none' });
  const r = spawnSync(OPENCLI, cmdArgs, { encoding: 'utf8', maxBuffer: 30 * 1024 * 1024, timeout, env });
  const out = { status: r?.status ?? 1, stdout: r?.stdout || '', stderr: r?.stderr || '', error: r?.error };
  emitEvent('opencli.end', { sub: `${cmdArgs[0]}:${cmdArgs[1] || ''}`, status: out.status, duration_ms: Date.now() - _t0 });
  return out;
}
let _t0 = 0;

// ─── sqlite (uses sqlite3 CLI) ───────────────────────────────────────────────
function ensureStore() {
  fs.mkdirSync(STORE_DIR, { recursive: true });
  fs.mkdirSync(CACHE_DIR, { recursive: true });
  fs.mkdirSync(TMP_DIR, { recursive: true });
  fs.mkdirSync(KEEP_DIR, { recursive: true });
  const schema = `
PRAGMA journal_mode=WAL;
PRAGMA synchronous=NORMAL;
CREATE TABLE IF NOT EXISTS meta (key TEXT PRIMARY KEY, value TEXT NOT NULL, updated_at TEXT NOT NULL);
CREATE TABLE IF NOT EXISTS accounts (name TEXT PRIMARY KEY, user_id TEXT, display_name TEXT, profile_url TEXT, created_at TEXT NOT NULL, last_used_at TEXT);
CREATE TABLE IF NOT EXISTS notifications (notif_id TEXT PRIMARY KEY, unread INTEGER, text TEXT, time TEXT, url TEXT, notif_type TEXT, account TEXT NOT NULL DEFAULT 'default', synced_at TEXT NOT NULL);
CREATE TABLE IF NOT EXISTS groups (url TEXT PRIMARY KEY, name TEXT, last_post TEXT, account TEXT NOT NULL DEFAULT 'default', synced_at TEXT NOT NULL);
CREATE TABLE IF NOT EXISTS chats (thread_id TEXT PRIMARY KEY, name TEXT, snippet TEXT, time TEXT, unread INTEGER, url TEXT, account TEXT NOT NULL DEFAULT 'default', synced_at TEXT NOT NULL);
CREATE TABLE IF NOT EXISTS messages (id INTEGER PRIMARY KEY AUTOINCREMENT, thread_id TEXT NOT NULL, from_me INTEGER, sender TEXT, text TEXT, time TEXT, account TEXT NOT NULL DEFAULT 'default', synced_at TEXT NOT NULL);
`;
  runSql(schema);
  migrateAddColumn('notifications', 'account', "TEXT NOT NULL DEFAULT 'default'");
  migrateAddColumn('groups', 'account', "TEXT NOT NULL DEFAULT 'default'");
  migrateAddColumn('chats', 'account', "TEXT NOT NULL DEFAULT 'default'");
  migrateAddColumn('messages', 'account', "TEXT NOT NULL DEFAULT 'default'");
  runSql(`
CREATE INDEX IF NOT EXISTS idx_notif_account_time ON notifications(account, time);
CREATE INDEX IF NOT EXISTS idx_messages_thread ON messages(thread_id);
CREATE INDEX IF NOT EXISTS idx_messages_account_time ON messages(account, time);
CREATE INDEX IF NOT EXISTS idx_chats_account ON chats(account);
CREATE INDEX IF NOT EXISTS idx_groups_account ON groups(account);
CREATE VIRTUAL TABLE IF NOT EXISTS messages_fts USING fts5(text, sender, thread_id UNINDEXED, account UNINDEXED, content='messages', content_rowid='id', tokenize='unicode61');
CREATE VIRTUAL TABLE IF NOT EXISTS notifications_fts USING fts5(text, notif_type, account UNINDEXED, content='notifications', content_rowid='rowid', tokenize='unicode61');
CREATE VIRTUAL TABLE IF NOT EXISTS groups_fts USING fts5(name, last_post, account UNINDEXED, content='groups', content_rowid='rowid', tokenize='unicode61');
`);
  rebuildFtsTriggers();
}
function migrateAddColumn(table, column, decl) {
  try {
    const cols = runSql(`PRAGMA table_info(${table});`);
    const has = cols.split('\n').some((l) => l.split('|')[1] === column);
    if (has) return false;
    runSql(`ALTER TABLE ${table} ADD COLUMN ${column} ${decl};`);
    runSql(`UPDATE ${table} SET ${column} = 'default' WHERE ${column} IS NULL;`);
    return true;
  } catch { return false; }
}
function rebuildFtsTriggers() {
  const drops = ['DROP TRIGGER IF EXISTS messages_ai;','DROP TRIGGER IF EXISTS messages_ad;','DROP TRIGGER IF EXISTS messages_au;','DROP TRIGGER IF EXISTS notif_ai;','DROP TRIGGER IF EXISTS notif_ad;','DROP TRIGGER IF EXISTS groups_ai;','DROP TRIGGER IF EXISTS groups_ad;'];
  const creates = [
    `CREATE TRIGGER IF NOT EXISTS messages_ai AFTER INSERT ON messages BEGIN INSERT INTO messages_fts(rowid, text, sender, thread_id, account) VALUES (new.id, COALESCE(new.text,''), COALESCE(new.sender,''), new.thread_id, new.account); END;`,
    `CREATE TRIGGER IF NOT EXISTS messages_ad AFTER DELETE ON messages BEGIN INSERT INTO messages_fts(messages_fts, rowid, text, sender, thread_id, account) VALUES('delete', old.id, COALESCE(old.text,''), COALESCE(old.sender,''), old.thread_id, old.account); END;`,
    `CREATE TRIGGER IF NOT EXISTS messages_au AFTER UPDATE ON messages BEGIN INSERT INTO messages_fts(messages_fts, rowid, text, sender, thread_id, account) VALUES('delete', old.id, COALESCE(old.text,''), COALESCE(old.sender,''), old.thread_id, old.account); INSERT INTO messages_fts(rowid, text, sender, thread_id, account) VALUES (new.id, COALESCE(new.text,''), COALESCE(new.sender,''), new.thread_id, new.account); END;`,
    `CREATE TRIGGER IF NOT EXISTS notif_ai AFTER INSERT ON notifications BEGIN INSERT INTO notifications_fts(rowid, text, notif_type, account) VALUES (new.rowid, COALESCE(new.text,''), COALESCE(new.notif_type,''), new.account); END;`,
    `CREATE TRIGGER IF NOT EXISTS notif_ad AFTER DELETE ON notifications BEGIN INSERT INTO notifications_fts(notifications_fts, rowid, text, notif_type, account) VALUES('delete', old.rowid, COALESCE(old.text,''), COALESCE(old.notif_type,''), old.account); END;`,
    `CREATE TRIGGER IF NOT EXISTS groups_ai AFTER INSERT ON groups BEGIN INSERT INTO groups_fts(rowid, name, last_post, account) VALUES (new.rowid, COALESCE(new.name,''), COALESCE(new.last_post,''), new.account); END;`,
    `CREATE TRIGGER IF NOT EXISTS groups_ad AFTER DELETE ON groups BEGIN INSERT INTO groups_fts(groups_fts, rowid, name, last_post, account) VALUES('delete', old.rowid, COALESCE(old.name,''), COALESCE(old.last_post,''), old.account); END;`,
  ];
  runSql(drops.join('\n') + '\n' + creates.join('\n'));
}
function ensureStoreOnly() { fs.mkdirSync(STORE_DIR, { recursive: true }); }
function runSql(sql, params = []) {
  ensureStoreOnly();
  if (params.length) {
    const quoted = params.map((p) => {
      if (p === null || p === undefined) return 'NULL';
      if (typeof p === 'number' && Number.isFinite(p)) return String(p);
      return `'${String(p).replace(/'/g, "''")}'`;
    });
    let i = 0;
    sql = sql.replace(/\?/g, () => quoted[i++] ?? 'NULL');
  }
  const r = spawnSync('sqlite3', [DB_PATH], { input: sql, encoding: 'utf8', maxBuffer: 20 * 1024 * 1024 });
  if (r.status !== 0) {
    const err = (r.stderr || r.stdout || 'sqlite3 failed').trim();
    throw new Error(err || `sqlite3 exit ${r.status}`);
  }
  return r.stdout;
}
const sqlEscape = (s) => String(s ?? '').replace(/'/g, "''");
const setMeta = (k, v) => {
  const ts = nowIso();
  runSql(`INSERT INTO meta(key,value,updated_at) VALUES('${sqlEscape(k)}','${sqlEscape(v)}','${ts}') ON CONFLICT(key) DO UPDATE SET value=excluded.value, updated_at=excluded.updated_at;`);
};
const getMeta = (k) => {
  const out = runSql(`SELECT value FROM meta WHERE key='${sqlEscape(k)}' LIMIT 1;`).trim();
  return out || null;
};

// ─── store lock ─────────────────────────────────────────────────────────────
function acquireLock({ wait = 0 } = {}) {
  ensureStoreOnly();
  if (fs.existsSync(LOCK_PATH)) {
    let owner = null;
    try { owner = JSON.parse(fs.readFileSync(LOCK_PATH, 'utf8')); } catch { /* */ }
    if (wait > 0) {
      const start = Date.now();
      while (Date.now() - start < wait * 1000) {
        if (!fs.existsSync(LOCK_PATH)) break;
        sleepMs(200);
      }
    }
    if (fs.existsSync(LOCK_PATH)) return { ok: false, owner, path: LOCK_PATH };
  }
  const payload = { pid: process.pid, user: os.userInfo().username, started_at: nowIso(), cmd: process.argv.slice(2).join(' ').slice(0, 200) };
  fs.writeFileSync(LOCK_PATH, JSON.stringify(payload, null, 2));
  const release = () => {
    try {
      const cur = JSON.parse(fs.readFileSync(LOCK_PATH, 'utf8'));
      if (cur.pid === process.pid) fs.unlinkSync(LOCK_PATH);
    } catch { /* */ }
  };
  process.on('exit', release);
  process.on('SIGINT', () => { release(); process.exit(130); });
  process.on('SIGTERM', () => { release(); process.exit(143); });
  return { ok: true, owner: payload };
}
function readLock() {
  if (!fs.existsSync(LOCK_PATH)) return null;
  try { return JSON.parse(fs.readFileSync(LOCK_PATH, 'utf8')); } catch { return null; }
}

// ─── read-only guard ────────────────────────────────────────────────────────
let _readOnlyActive = false;
let _jsonActive = false;
function rejectIfReadOnly(action) {
  if (_readOnlyActive) die(`refusing to ${action}: read-only mode (set FB_READONLY=0 or drop --read-only)`, EXIT.READ_ONLY, { json: _jsonActive });
}

// ─── output helpers ─────────────────────────────────────────────────────────
function tryParseJson(text) {
  const t = (text || '').trim();
  if (!t) return null;
  try { return JSON.parse(t); } catch {
    const sObj = t.indexOf('{'), sArr = t.indexOf('[');
    let s = -1;
    if (sObj >= 0 && sArr >= 0) s = Math.min(sObj, sArr); else s = Math.max(sObj, sArr);
    if (s < 0) return null;
    try { return JSON.parse(t.slice(s)); } catch { return null; }
  }
}
function asRows(parsed) {
  if (parsed == null) return [];
  if (Array.isArray(parsed)) return parsed;
  if (typeof parsed === 'object') {
    if (Array.isArray(parsed.data)) return parsed.data;
    if (Array.isArray(parsed.results)) return parsed.results;
    return [parsed];
  }
  return [];
}
function stamp(payload, kind) {
  if (Array.isArray(payload)) return { version: VERSION, program: PROGRAM, account: _account, kind, count: payload.length, data: payload };
  return { version: VERSION, program: PROGRAM, account: _account, kind, ...payload };
}
function emit(rows, opts = {}) {
  const { json, plain, noColor, full, kind = 'result' } = opts;
  if (json) {
    const payload = Array.isArray(rows)
      ? (rows.length === 1 && !Array.isArray(rows[0]) ? stamp(rows[0], kind) : stamp(rows, kind))
      : stamp(rows, kind);
    console.log(JSON.stringify(payload, null, 2));
    return;
  }
  if (plain) {
    for (const row of rows) {
      if (row && typeof row === 'object') console.log(Object.values(row).join('\t'));
      else console.log(row);
    }
    return;
  }
  printTable(rows, { noColor, full });
}
function color(s, c, enabled) { return enabled ? `\x1b[${c}m${s}\x1b[0m` : String(s); }
function printTable(rows, { noColor = true, full = false } = {}) {
  if (!rows.length) { console.log('(empty)'); return; }
  const keys = Object.keys(rows[0]);
  const widths = keys.map((k) => Math.min(full ? 200 : 60, Math.max(k.length, ...rows.map((r) => String(r[k] ?? '').length))));
  const fmt = (vals) => vals.map((v, i) => String(v ?? '').padEnd(widths[i]).slice(0, widths[i])).join('  ');
  const dim = (s) => color(s, '2', !noColor);
  const head = (s) => color(s, '1', !noColor);
  console.log(head(fmt(keys)));
  console.log(dim(widths.map((w) => '-'.repeat(w)).join('  ')));
  for (const row of rows) console.log(fmt(keys.map((k) => row[k])));
  console.log(`\n${rows.length} row(s)`);
}
function printRaw(result, { json }) {
  if (result.stdout) process.stdout.write(result.stdout.endsWith('\n') ? result.stdout : result.stdout + '\n');
  if (result.stderr && result.status !== 0) process.stderr.write(result.stderr);
  if (result.error) console.error(String(result.error.message || result.error));
  process.exit(result.status === 0 ? EXIT.OK : (result.status || EXIT.OPENCLI_FAIL));
}

// ─── facebook arg routing ───────────────────────────────────────────────────
function effectiveWindow(g, { force } = {}) {
  if (force) return force;
  if (g.window === 'foreground' || g.window === 'background') return g.window;
  return 'background';
}
function facebookArgs(sub, extra = [], g, windowMode) {
  const args = ['facebook', sub, ...extra];
  if (g.limit != null) args.push('--limit', String(g.limit));
  const mode = windowMode || effectiveWindow(g);
  args.push('--window', mode);
  return args;
}
function runFacebook(sub, extra, g, opts = {}) {
  const mode = effectiveWindow(g, opts);
  const result = opencli(facebookArgs(sub, extra, g, mode), {
    json: true, windowMode: mode, timeout: opts.timeout || 180000,
  });
  const parsed = result.status === 0 ? tryParseJson(result.stdout) : null;
  if (parsed) { emit(asRows(parsed), { json: g.json, plain: g.plain, noColor: g.noColor, full: g.full, kind: sub }); return; }
  printRaw(result, { json: g.json });
}

function doctorConnected() {
  // doctorConnected is a passive probe — never auto-start for it.
  // Use bridgeStr() (the URL string), not bridgeCheck (the object).
  const r = spawnSync(OPENCLI, ['doctor'], { encoding: 'utf8', timeout: 45000, env: { ...process.env, OPENCLI_CDP_ENDPOINT: chromeStr().split(' ')[0] || '' } });
  const out = `${r.stdout || ''}\n${r.stderr || ''}`;
  const ok = r.status === 0 && (/Extension:\s*connected/i.test(out) || /Everything looks good/i.test(out));
  return { ok, out, status: r.status };
}
function facebookLoggedIn() {
  const r = opencli(['facebook', 'whoami', '-f', 'json'], { json: true, timeout: 90000, windowMode: 'background' });
  const me = r.status === 0 ? tryParseJson(r.stdout) : null;
  const ok = Boolean(me && (me.logged_in === true || me.user_id));
  return { ok, me, raw: r };
}

// ─── daemon state ────────────────────────────────────────────────────────────
function writeDaemonState(state) {
  ensureStoreOnly();
  fs.writeFileSync(DAEMON_STATE, JSON.stringify({ ...state, updated_at: nowIso() }, null, 2));
}
function readDaemonState() {
  try { return JSON.parse(fs.readFileSync(DAEMON_STATE, 'utf8')); } catch { return null; }
}

