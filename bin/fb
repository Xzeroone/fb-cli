function cmdVersion(g) {
  const bridge = bridgeCheck({ autoStart: false });
  const info = {
    version: VERSION, program: PROGRAM, node: process.version,
    opencli: which(OPENCLI) || OPENCLI,
    bridge_ok: bridge.ok,
    daemon: bridge.url || null,
    chrome: bridge.chrome ? { url: bridge.chrome.url, headless: bridge.chrome.headless } : null,
    bridge_detail: bridge.ok ? null : bridge.reason,
    store: cfgStore(),
    config: fileExists(CONFIG_PATH) ? CONFIG_PATH : null,
    account: g.account,
  };
  if (g.json) console.log(JSON.stringify(info, null, 2));
  else {
    console.log(`${PROGRAM} ${VERSION}`);
    console.log(`  node:     ${info.node}`);
    console.log(`  opencli:  ${info.opencli}`);
    console.log(`  bridge:   ${bridgeStr()}`);
    console.log(`  store:    ${info.store}`);
    console.log(`  config:   ${info.config || '(none)'}`);
    console.log(`  account:  ${info.account}`);
  }
}

function cmdCompletion(g, args) {
  const shell = args[0] || 'bash';
  const scripts = {
    bash: `
_fb_completions() {
  local cur cmds
  COMPREPLY=()
  cur="\${COMP_WORDS[COMP_CWORD]}"
  cmds="setup connect onboard daemon auth login whoami status check doctor version completion accounts store profile sync home feed notifications notifs groups friends search posts search-posts post read-post research chats messages inbox thread read media pull download-media open keep purge send add-friend join-group events memories marketplace db docs help"
  if [[ \${cur} == -* ]]; then
    COMPREPLY=( \$(compgen -W "--json --events --read-only --plain --full --no-color --account --store --timeout --limit --window --help --version" -- "\${cur}") )
    return 0
  fi
  COMPREPLY=( \$(compgen -W "\${cmds}" -- "\${cur}") )
}
complete -F _fb_completions fb
`,
    zsh: `#compdef fb
_fb() {
  local -a subcommands
  subcommands=('setup:Guided connect' 'connect:Alias for setup' 'onboard:Alias for setup' 'daemon:opencli daemon manager' 'auth:Visible login' 'login:Alias for auth' 'whoami:Show account' 'status:Health summary' 'check:Alias for status' 'doctor:opencli + FB + store' 'version:Print version' 'completion:Shell completion' 'accounts:Multi-account' 'store:Store introspection' 'profile:Public profile' 'sync:Pull to local store' 'home:Home feed' 'feed:Alias for home' 'notifications:List notifications' 'notifs:Alias for notifications' 'groups:List groups' 'friends:List friends' 'search:Top results' 'posts:Public post search' 'search-posts:Alias for posts' 'post:Read one public post' 'read-post:Alias for post' 'research:Posts + deep-read' 'chats:List chats' 'messages:Store queries' 'inbox:Alias for chats' 'thread:Read one thread' 'read:Alias for thread' 'media:Download media' 'pull:Alias for media' 'download-media:Alias for media' 'open:Open downloaded file' 'keep:Move to keep/' 'purge:Delete tmp' 'send:Send a message' 'add-friend:Send friend request' 'join-group:Join group' 'events:List events' 'memories:List memories' 'marketplace:Marketplace queries' 'db:Raw store queries' 'docs:Repo / docs URL' 'help:Show help')
  _arguments -s '--json[JSON]' '--events[NDJSON events]' '--read-only[Refuse writes]' '--plain[TSV]' '--full[No truncation]' '--no-color[No colors]' '--account[Account name]:name:' '--store[Store dir]:dir:_files' '--timeout[Timeout]:duration:' '--limit[Row limit]:n:' '--window[Window mode]:mode:(background foreground)' '(-h --help)'{-h,--help}'[Help]' '(-V --version)'{-V,--version}'[Version]' '*::subcommand:->subcmd'
  case \$state in subcmd) _describe -t subcommands 'fb subcommand' subcommands ;; esac
}
_fb "\$@"
`,
    fish: `function __fb_subcommands
  echo setup connect onboard daemon auth login whoami status check doctor version completion accounts store profile sync home feed notifications notifs groups friends search posts search-posts post read-post research chats messages inbox thread read media pull download-media open keep purge send add-friend join-group events memories marketplace db docs help
end
complete -c fb -f -n "__fish_use_subcommand" -a "(__fb_subcommands)"
complete -c fb -l json -d 'JSON output' -l events -d 'NDJSON events' -l read-only -d 'Refuse writes' -l plain -d 'TSV' -l full -d 'No truncation' -l no-color -d 'No colors' -l account -d 'Account name' -r -l store -d 'Store dir' -r -l timeout -d 'Timeout' -r -l limit -d 'Row limit' -r -l window -d 'Window mode' -r
`,
    pwsh: `$fb_completer = {
  param($wordToComplete)
  $cmds = @('setup','connect','onboard','daemon','auth','login','whoami','status','check','doctor','version','completion','accounts','store','profile','sync','home','feed','notifications','notifs','groups','friends','search','posts','search-posts','post','read-post','research','chats','messages','inbox','thread','read','media','pull','download-media','open','keep','purge','send','add-friend','join-group','events','memories','marketplace','db','docs','help')
  $flags = @('--json','--events','--read-only','--plain','--full','--no-color','--account','--store','--timeout','--limit','--window','--help','--version')
  $candidates = $cmds + $flags
  $candidates | Where-Object { $_ -like "$wordToComplete*" } | ForEach-Object {
    [System.Management.Automation.CompletionResult]::new($_, $_, 'Parameter', $_)
  }
}
`,
  };
  const s = scripts[shell];
  if (!s) die(`unknown shell: ${shell}. Try: bash | zsh | fish | pwsh`, EXIT.USAGE, { json: g.json });
  process.stdout.write(s.trimStart());
  if (g.json) process.stderr.write(JSON.stringify({ ok: true, shell, bytes: s.length }, null, 2));
}

function cmdAccounts(g, args) {
  ensureStore();
  const sub = args[0] || 'list';
  if (sub === 'list' || sub === 'ls') {
    const rows = runSql(`SELECT name, COALESCE(user_id,'') AS user_id, COALESCE(display_name,'') AS display_name, created_at, COALESCE(last_used_at,'-') AS last_used_at FROM accounts ORDER BY name;`);
    if (g.json) {
      const arr = rows.split('\n').filter(Boolean).map((l) => l.split('|'));
      const keys = ['name','user_id','display_name','created_at','last_used_at'];
      emit(arr.map((v) => Object.fromEntries(keys.map((k, i) => [k, v[i]]))), { json: true, kind: 'accounts.list' });
      return;
    }
    if (!rows.trim()) { console.log('(no accounts — run `fb auth`)'); return; }
    const lines = rows.trim().split('\n');
    const keys = ['name','user_id','display_name','created_at','last_used_at'];
    emit(lines.map((l) => Object.fromEntries(keys.map((k, i) => [k, l.split('|')[i]]))), { json: g.json, plain: g.plain, noColor: g.noColor, kind: 'accounts.list' });
  } else if (sub === 'add') {
    const name = args[1]; if (!name) die('Usage: fb accounts add <name>', EXIT.USAGE, { json: g.json });
    rejectIfReadOnly('add account');
    const ts = nowIso();
    runSql(`INSERT INTO accounts(name, created_at) VALUES('${sqlEscape(name)}','${ts}') ON CONFLICT(name) DO NOTHING;`);
    emit({ ok: true, name, created_at: ts }, { json: g.json, kind: 'accounts.add' });
  } else if (sub === 'use') {
    const name = args[1]; if (!name) die('Usage: fb accounts use <name>', EXIT.USAGE, { json: g.json });
    const exists = runSql(`SELECT 1 FROM accounts WHERE name='${sqlEscape(name)}';`).trim();
    if (!exists) die(`unknown account: ${name}`, EXIT.NOT_FOUND, { json: g.json });
    setMeta('current_account', name);
    emit({ ok: true, account: name }, { json: g.json, kind: 'accounts.use' });
  } else if (sub === 'rm' || sub === 'remove') {
    const name = args[1]; if (!name) die('Usage: fb accounts rm <name>', EXIT.USAGE, { json: g.json });
    rejectIfReadOnly('remove account');
    runSql(`DELETE FROM accounts WHERE name='${sqlEscape(name)}';`);
    emit({ ok: true, removed: name }, { json: g.json, kind: 'accounts.rm' });
  } else if (sub === '--help' || sub === 'help') {
    console.log(`fb accounts — manage named accounts\n\n  fb accounts list\n  fb accounts add <name>\n  fb accounts use <name>\n  fb accounts rm <name>\n  fb --account NAME ...        # per-command override`);
  } else {
    die(`unknown accounts subcommand: ${sub}`, EXIT.USAGE, { json: g.json });
  }
}

function cmdStore(g, args) {
  ensureStore();
  const sub = args[0] || 'info';
  if (sub === 'info') {
    const dbSize = fs.existsSync(DB_PATH) ? fs.statSync(DB_PATH).size : 0;
    const lock = readLock();
    const counts = {
      accounts: Number(runSql('SELECT COUNT(*) FROM accounts;').trim() || 0),
      notifications: Number(runSql('SELECT COUNT(*) FROM notifications;').trim() || 0),
      groups: Number(runSql('SELECT COUNT(*) FROM groups;').trim() || 0),
      chats: Number(runSql('SELECT COUNT(*) FROM chats;').trim() || 0),
      messages: Number(runSql('SELECT COUNT(*) FROM messages;').trim() || 0),
    };
    const fts = {
      messages_fts: Number(runSql('SELECT COUNT(*) FROM messages_fts;').trim() || 0),
      notifications_fts: Number(runSql('SELECT COUNT(*) FROM notifications_fts;').trim() || 0),
      groups_fts: Number(runSql('SELECT COUNT(*) FROM groups_fts;').trim() || 0),
    };
    const cdp = daemonStr();
    const payload = { path: STORE_DIR, db: DB_PATH, db_size: dbSize, lock, counts, fts, cdp, last_sync: getMeta('last_sync') };
    if (g.json) console.log(JSON.stringify(stamp(payload, 'store.info'), null, 2));
    else {
      console.log(`fb store`);
      console.log(`  path:      ${STORE_DIR}`);
      console.log(`  db:        ${DB_PATH}  (${(dbSize/1024).toFixed(1)} KB)`);
      console.log(`  cdp:       ${cdp || 'NOT FOUND'}`);
      console.log(`  lock:      ${lock ? `held by pid=${lock.pid} user=${lock.user}` : 'free'}`);
      console.log(`  fts:       messages=${fts.messages_fts}  notifs=${fts.notifications_fts}  groups=${fts.groups_fts}`);
      console.log(`  counts:    ${JSON.stringify(counts)}`);
      console.log(`  last_sync: ${payload.last_sync || '(never)'}`);
    }
  } else if (sub === 'prune') {
    rejectIfReadOnly('prune store');
    const days = Number(args[1] || 90);
    const cutoff = new Date(Date.now() - days * 86400_000).toISOString();
    const before = {
      notifs: Number(runSql('SELECT COUNT(*) FROM notifications;').trim() || 0),
      groups: Number(runSql('SELECT COUNT(*) FROM groups;').trim() || 0),
      chats: Number(runSql('SELECT COUNT(*) FROM chats;').trim() || 0),
      messages: Number(runSql('SELECT COUNT(*) FROM messages;').trim() || 0),
    };
    runSql(`DELETE FROM notifications WHERE synced_at < '${cutoff}';`);
    runSql(`DELETE FROM groups WHERE synced_at < '${cutoff}';`);
    runSql(`DELETE FROM chats WHERE synced_at < '${cutoff}';`);
    runSql(`DELETE FROM messages WHERE synced_at < '${cutoff}';`);
    runSql('VACUUM;');
    const after = {
      notifs: Number(runSql('SELECT COUNT(*) FROM notifications;').trim() || 0),
      groups: Number(runSql('SELECT COUNT(*) FROM groups;').trim() || 0),
      chats: Number(runSql('SELECT COUNT(*) FROM chats;').trim() || 0),
      messages: Number(runSql('SELECT COUNT(*) FROM messages;').trim() || 0),
    };
    const payload = { cutoff, days, before, after };
    if (g.json) console.log(JSON.stringify(stamp({ ...payload, ok: true }, 'store.prune'), null, 2));
    else {
      console.log(`fb store prune: removed rows synced before ${cutoff}`);
      for (const k of Object.keys(before)) console.log(`  ${k.padEnd(10)} ${before[k]} → ${after[k]}  (Δ ${after[k] - before[k]})`);
    }
  } else if (sub === 'reset') {
    rejectIfReadOnly('reset store');
    if (!g.json) console.error('fb store reset: removing db + cache (not keep/, not tmp/)');
    fs.rmSync(DB_PATH, { force: true });
    for (const f of fs.readdirSync(CACHE_DIR)) fs.rmSync(path.join(CACHE_DIR, f), { recursive: true, force: true });
    ensureStore();
    if (g.json) console.log(JSON.stringify({ ok: true, action: 'reset', path: STORE_DIR }, null, 2));
  } else if (sub === 'lock') {
    const wait = Number(args[1] || 0);
    const r = acquireLock({ wait });
    if (g.json) console.log(JSON.stringify(r, null, 2));
    else if (r.ok) console.log(`lock acquired (pid=${r.owner.pid})`);
    else { console.error(`locked by pid=${lock.owner?.pid} user=${lock.owner?.user} since ${lock.owner?.started_at}`); process.exit(EXIT.LOCKED); }
  } else if (sub === '--help' || sub === 'help') {
    console.log(`fb store — local SQLite store introspection\n\n  fb store info             Counts, sizes, lock holder, FTS indexes, CDP\n  fb store prune [days]     Delete rows older than <days> (default 90), then VACUUM\n  fb store reset            Delete the db + cache (keeps keep/ and tmp/)\n  fb store lock [wait_sec]  Try to acquire the store lock`);
  } else {
    die(`unknown store subcommand: ${sub}`, EXIT.USAGE, { json: g.json });
  }
}

function cmdDocs(g) {
  const url = 'https://github.com/xzeroone/fb-cli';
  const payload = { program: PROGRAM, version: VERSION, repo: url, wacli_parity: true };
  if (g.json) console.log(JSON.stringify(payload, null, 2));
  else {
    console.log(`${PROGRAM} ${VERSION}`);
    console.log(`  repo:    ${url}`);
    console.log(`  wacli parity: yes (--json, --events, --read-only, --account, --store, --timeout, FTS5, lock)`);
  }
}

function cmdProfile(g, args) {
  const sub = args[0];
  if (!sub || sub === '--help' || sub === 'help') {
    console.log(`fb profile — public profile lookup or own profile\n\n  fb profile <username>             Fetch a public profile\n  fb profile set --display <name>   Update your own display name (best-effort, opencli)\n  fb profile whoami                 Show your own profile as JSON`);
    return;
  }
  if (sub === 'set') {
    rejectIfReadOnly('set profile');
    let display = null, bio = null, website = null;
    for (let i = 1; i < args.length; i += 1) {
      const a = args[i];
      if (a === '--display') display = args[++i];
      else if (a === '--bio') bio = args[++i];
      else if (a === '--website') website = args[++i];
    }
    if (!display && !bio && !website) die('Usage: fb profile set --display <name> [--bio <bio>] [--website <url>]', EXIT.USAGE, { json: g.json });
    const auth = facebookLoggedIn();
    if (!auth.ok) die('not authenticated — run: fb auth', EXIT.NOT_AUTHED, { json: g.json });
    const extra = [];
    if (display) extra.push('--display', display);
    if (bio) extra.push('--bio', bio);
    if (website) extra.push('--website', website);
    const r = opencli(['facebook', 'profile-set', ...extra, '-f', 'json'], { json: true, windowMode: 'foreground' });
    printRaw(r, { json: g.json });
  } else if (sub === 'whoami') {
    runFacebook('whoami', [], g);
  } else {
    runFacebook('profile', [sub], g);
  }
}

function cmdMessages(g, args) {
  const sub = args[0] || 'list';
  if (sub === 'list' || sub === 'ls') {
    const limit = Number(g.limit || 50);
    const chat = args[1] || null;
    const since = args[2] || null;
    const params = [];
    let where = '1=1';
    if (chat) { where += ' AND thread_id = ?'; params.push(chat); }
    if (since) {
      const iso = parseSince(since);
      if (iso) { where += ' AND time >= ?'; params.push(iso); }
    }
    const sql = `SELECT id, thread_id, COALESCE(sender,'-') AS sender, CASE WHEN from_me=1 THEN 'me' ELSE 'them' END AS dir, substr(text,1,200) AS text, time FROM messages WHERE ${where} AND account = ? ORDER BY id DESC LIMIT ?;`;
    params.push(_account, limit);
    const out = runSql(sql, params);
    const rows = out.split('\n').filter(Boolean).map((l) => l.split('|'));
    const keys = ['id','thread_id','sender','dir','text','time'];
    if (g.json) { emit(rows.map((v) => Object.fromEntries(keys.map((k, i) => [k, v[i]]))), { json: true, kind: 'messages.list' }); return; }
    emit(rows.map((v) => Object.fromEntries(keys.map((k, i) => [k, v[i]]))), { json: false, plain: g.plain, noColor: g.noColor, kind: 'messages.list' });
  } else if (sub === 'show') {
    const id = args[1]; if (!id) die('Usage: fb messages show <id>', EXIT.USAGE, { json: g.json });
    const out = runSql(`SELECT id, thread_id, sender, CASE WHEN from_me=1 THEN 'me' ELSE 'them' END AS dir, text, time, synced_at FROM messages WHERE id = ? AND account = ? LIMIT 1;`, [id, _account]);
    if (!out.trim()) die(`message not found: ${id}`, EXIT.NOT_FOUND, { json: g.json });
    const [vals] = out.trim().split('\n').map((l) => l.split('|'));
    const keys = ['id','thread_id','sender','dir','text','time','synced_at'];
    const row = Object.fromEntries(keys.map((k, i) => [k, vals[i]]));
    if (g.json) console.log(JSON.stringify(stamp(row, 'messages.show'), null, 2));
    else { for (const [k, v] of Object.entries(row)) console.log(`  ${k.padEnd(10)} ${v}`); }
  } else if (sub === 'search') {
    const q = args.slice(1).join(' ').trim();
    if (!q) die('Usage: fb messages search <query>', EXIT.USAGE, { json: g.json });
    const limit = Number(g.limit || 25);
    let ftsAvailable = true;
    let rows = [];
    try {
      const sql = `SELECT m.id, m.thread_id, COALESCE(m.sender,'-') AS sender, CASE WHEN m.from_me=1 THEN 'me' ELSE 'them' END AS dir, m.text, m.time FROM messages_fts f JOIN messages m ON m.id = f.rowid WHERE messages_fts MATCH ? AND m.account = ? ORDER BY rank LIMIT ?;`;
      const out = runSql(sql, [ftsQuery(q), _account, limit]);
      rows = out.split('\n').filter(Boolean).map((l) => l.split('|'));
    } catch (e) {
      ftsAvailable = false;
      const sql = `SELECT id, thread_id, COALESCE(sender,'-') AS sender, CASE WHEN from_me=1 THEN 'me' ELSE 'them' END AS dir, text, time FROM messages WHERE text LIKE ? AND account = ? ORDER BY id DESC LIMIT ?;`;
      const out = runSql(sql, [`%${q}%`, _account, limit]);
      rows = out.split('\n').filter(Boolean).map((l) => l.split('|'));
    }
    const keys = ['id','thread_id','sender','dir','text','time'];
    const data = rows.map((v) => Object.fromEntries(keys.map((k, i) => [k, v[i]])));
    if (g.json) { console.log(JSON.stringify(stamp({ query: q, fts: ftsAvailable, count: data.length, data }, 'messages.search'), null, 2)); return; }
    if (!data.length) { console.log('(no matches)'); return; }
    emit(data, { json: false, plain: g.plain, noColor: g.noColor, kind: 'messages.search' });
  } else if (sub === '--help' || sub === 'help') {
    console.log(`fb messages — local store queries (offline after sync)\n\n  fb messages list [chat] [since]      List messages\n  fb messages show <id>                Show one message\n  fb messages search <query>           FTS5 search (or LIKE fallback)`);
  } else {
    die(`unknown messages subcommand: ${sub}`, EXIT.USAGE, { json: g.json });
  }
}

function parseSince(s) {
  if (!s) return null;
  const rel = s.match(/^(\d+)([smhdw])$/);
  if (rel) {
    const n = Number(rel[1]);
    const unit = { s: 1, m: 60, h: 3600, d: 86400, w: 604800 }[rel[2]];
    return new Date(Date.now() - n * unit * 1000).toISOString();
  }
  const d = new Date(s);
  if (!isNaN(d.getTime())) return d.toISOString();
  return null;
}
function ftsQuery(q) {
  return q.split(/\s+/).filter(Boolean).map((t) => `"${t.replace(/"/g, '""')}"*`).join(' ');
}

// ─── daemon (now just wraps opencli) ────────────────────────────────────────
function cmdDaemon(g, args) {
  const action = args[0] || 'status';
  const cdp = daemonStr();

  if (action === 'start' || action === 'restart') {
    // opencli daemon: starts the opencli Node bridge on 19825
    const r = spawnSync(OPENCLI, ['daemon', action === 'restart' ? 'restart' : 'start'], { encoding: 'utf8', timeout: 30000 });
    sleepMs(800);
    const cdpAfter = daemonCheck();
    const doctor = spawnSync(OPENCLI, ['doctor'], { encoding: 'utf8', timeout: 30000 });
    const who = opencli(['facebook', 'whoami', '-f', 'json'], { json: true, timeout: 60000 });
    const me = who.status === 0 ? tryParseJson(who.stdout) : null;
    const state = { running: true, cdp: cdpAfter, doctor_ok: doctor.status === 0, authenticated: Boolean(me?.logged_in || me?.user_id), user_id: me?.user_id || null };
    writeDaemonState(state);
    if (g.json) console.log(JSON.stringify(stamp(state, 'daemon.start'), null, 2));
    else {
      console.log(`fb daemon ${action} via opencli`);
      console.log(`  cdp:       ${state.cdp || 'NOT FOUND'}`);
      console.log(`  opencli:   ${state.doctor_ok ? 'ok' : 'FAIL'}`);
      console.log(`  auth:      ${state.authenticated ? `yes (user_id=${state.user_id})` : 'no — run: fb auth'}`);
      if (!state.cdp) console.log('  tip:       if you want zero visible UI, run: fb-headless start');
    }
    process.exit(state.doctor_ok ? EXIT.OK : EXIT.OPENCLI_FAIL);
  }
  if (action === 'stop') {
    spawnSync(OPENCLI, ['daemon', 'stop'], { encoding: 'utf8', timeout: 15000 });
    writeDaemonState({ running: false });
    if (g.json) console.log(JSON.stringify({ running: false }, null, 2)); else console.log('fb daemon stopped (Chrome left alone — close it manually if you want)');
    process.exit(EXIT.OK);
  }
  if (action === 'status' || action === 'check') {
    const st = readDaemonState() || {};
    const doctor = spawnSync(OPENCLI, ['doctor'], { encoding: 'utf8', timeout: 30000 });
    const who = opencli(['facebook', 'whoami', '-f', 'json'], { json: true, timeout: 60000 });
    const me = who.status === 0 ? tryParseJson(who.stdout) : null;
    const status = { version: VERSION, cdp, daemon_state: st, doctor_ok: doctor.status === 0, authenticated: Boolean(me?.logged_in || me?.user_id), account: me, store: STORE_DIR };
    if (g.json) console.log(JSON.stringify(stamp(status, 'daemon.status'), null, 2));
    else {
      console.log(`fb daemon status (v${VERSION})`);
      console.log(`  cdp:          ${cdp || 'NOT FOUND'}`);
      console.log(`  opencli:      ${status.doctor_ok ? 'ok' : 'FAIL'}`);
      console.log(`  authenticated: ${status.authenticated ? 'yes' : 'no'}`);
      if (me?.user_id) console.log(`  user_id:      ${me.user_id}`);
      console.log(`  store:        ${STORE_DIR}`);
    }
    process.exit(status.doctor_ok && status.authenticated ? EXIT.OK : EXIT.OPENCLI_FAIL);
  }
  die('Usage: fb daemon start|stop|status|restart', EXIT.USAGE, { json: g.json });
}

function cmdStatus(g) {
  ensureStore();
  const doctor = opencli(['doctor'], { json: false, timeout: 60000 });
  const who = opencli(['facebook', 'whoami', '-f', 'json'], { json: true, timeout: 120000 });
  const me = who.status === 0 ? tryParseJson(who.stdout) : null;
  const lastSync = getMeta('last_sync');
  const counts = {
    notifications: Number(runSql(`SELECT COUNT(*) FROM notifications WHERE account='${sqlEscape(_account)}';`).trim() || 0),
    groups: Number(runSql(`SELECT COUNT(*) FROM groups WHERE account='${sqlEscape(_account)}';`).trim() || 0),
    chats: Number(runSql(`SELECT COUNT(*) FROM chats WHERE account='${sqlEscape(_account)}';`).trim() || 0),
    messages: Number(runSql(`SELECT COUNT(*) FROM messages WHERE account='${sqlEscape(_account)}';`).trim() || 0),
  };
  const fts = {
    messages: Number(runSql('SELECT COUNT(*) FROM messages_fts;').trim() || 0),
    notifications: Number(runSql('SELECT COUNT(*) FROM notifications_fts;').trim() || 0),
    groups: Number(runSql('SELECT COUNT(*) FROM groups_fts;').trim() || 0),
  };
  const cdp = daemonStr();
  const status = { version: VERSION, opencli: OPENCLI, cdp, store: DB_PATH, authenticated: Boolean(me?.logged_in || me?.user_id), account: me, last_sync: lastSync, local_counts: counts, fts, doctor_ok: doctor.status === 0 };
  if (g.json) console.log(JSON.stringify(stamp(status, 'status'), null, 2));
  else {
    console.log(`fb ${VERSION}`);
    console.log(`  opencli:    ${OPENCLI}`);
    console.log(`  cdp:        ${cdp || 'NOT FOUND'}`);
    console.log(`  store:      ${DB_PATH}`);
    console.log(`  doctor:     ${status.doctor_ok ? 'ok' : 'FAIL'}`);
    console.log(`  auth:       ${status.authenticated ? 'yes' : 'no'}${me?.user_id ? ` (user_id=${me.user_id})` : ''}`);
    console.log(`  last_sync:  ${lastSync || '(never)'}`);
    console.log(`  local:      notifs=${counts.notifications} groups=${counts.groups} chats=${counts.chats} messages=${counts.messages}`);
    console.log(`  fts:        messages=${fts.messages} notifs=${fts.notifications} groups=${fts.groups}`);
    if (!cdp) console.log('\nNo CDP endpoint found. Run: opencli facebook login');
    if (!status.authenticated) console.log('\nRun: fb auth');
  }
  process.exit(status.authenticated && status.doctor_ok ? EXIT.OK : EXIT.NOT_AUTHED);
}

function cmdDoctor(g) {
  const r = opencli(['doctor'], { json: false });
  process.stdout.write(r.stdout || '');
  process.stderr.write(r.stderr || '');
  console.log('\n--- Facebook session ---');
  const who = opencli(['facebook', 'whoami', '-f', 'json'], { json: true });
  if (who.status === 0) console.log(who.stdout.trim());
  else { console.log('Not authenticated or whoami failed.'); console.log((who.stderr || who.stdout || '').trim().slice(0, 400)); }
  console.log('\n--- Store ---');
  try { cmdStore({ ...g, json: false }, ['info']); } catch (e) { console.log(`store: ${e.message}`); }
  process.exit(r.status === 0 && who.status === 0 ? EXIT.OK : EXIT.OPENCLI_FAIL);
}

function cmdSync(g) {
  ensureStore();
  const lock = acquireLock({ wait: Number(g.timeout || 30) });
  if (!lock.ok) die(`store locked by pid=${lock.owner?.pid} user=${lock.owner?.user} (started ${lock.owner?.started_at})`, EXIT.LOCKED, { json: g.json });
  rejectIfReadOnly('sync');
  const limit = g.limit || '30';
  const report = { ok: true, notifications: 0, groups: 0, chats: 0, errors: [], account: _account };
  const ts = nowIso();

  function pull(name, opencliSub) {
    const r = opencli(['facebook', opencliSub, '--limit', String(limit), '-f', 'json'], { json: true, timeout: 180000 });
    if (r.status !== 0) { report.errors.push({ name, error: (r.stderr || r.stdout || 'failed').trim().slice(0, 300) }); return []; }
    return asRows(tryParseJson(r.stdout));
  }

  try {
    for (const row of pull('notifications', 'notifications')) {
      const id = row.notif_id || row.Notif_id || row.url || `${row.text}-${row.time}`;
      runSql(`INSERT INTO notifications(notif_id,unread,text,time,url,notif_type,account,synced_at) VALUES('${sqlEscape(id)}',${row.unread ? 1 : 0},'${sqlEscape(row.text)}','${sqlEscape(row.time)}','${sqlEscape(row.url)}','${sqlEscape(row.notif_type || row.Notif_type)}','${sqlEscape(_account)}','${ts}') ON CONFLICT(notif_id) DO UPDATE SET unread=excluded.unread, text=excluded.text, time=excluded.time, url=excluded.url, notif_type=excluded.notif_type, account=excluded.account, synced_at=excluded.synced_at;`);
    }
    report.notifications = Number(runSql(`SELECT COUNT(*) FROM notifications WHERE account='${sqlEscape(_account)}';`).trim() || 0);
  } catch (e) { report.errors.push({ name: 'notifications', error: String(e.message || e) }); }
  try {
    for (const row of pull('groups', 'groups')) {
      const url = row.url || row.Url || row.name;
      runSql(`INSERT INTO groups(url,name,last_post,account,synced_at) VALUES('${sqlEscape(url)}','${sqlEscape(row.name)}','${sqlEscape(row.last_post || row.Last_post || '')}','${sqlEscape(_account)}','${ts}') ON CONFLICT(url) DO UPDATE SET name=excluded.name, last_post=excluded.last_post, account=excluded.account, synced_at=excluded.synced_at;`);
    }
    report.groups = Number(runSql(`SELECT COUNT(*) FROM groups WHERE account='${sqlEscape(_account)}';`).trim() || 0);
  } catch (e) { report.errors.push({ name: 'groups', error: String(e.message || e) }); }
  try {
    for (const row of pull('chats', 'messages')) {
      const tid = row.thread_id || row.threadId;
      if (!tid) continue;
      runSql(`INSERT INTO chats(thread_id,name,snippet,time,unread,url,account,synced_at) VALUES('${sqlEscape(tid)}','${sqlEscape(row.name)}','${sqlEscape(row.snippet)}','${sqlEscape(row.time)}',${row.unread ? 1 : 0},'${sqlEscape(row.url)}','${sqlEscape(_account)}','${ts}') ON CONFLICT(thread_id) DO UPDATE SET name=excluded.name, snippet=excluded.snippet, time=excluded.time, unread=excluded.unread, url=excluded.url, account=excluded.account, synced_at=excluded.synced_at;`);
      if (Array.isArray(row.messages)) {
        for (const m of row.messages) {
          runSql(`INSERT INTO messages(thread_id,from_me,sender,text,time,account,synced_at) VALUES(?,?,?,?,?,?,?);`, [tid, m.from_me ? 1 : 0, m.sender || null, m.text || '', m.time || '', _account, ts]);
        }
      }
    }
    report.chats = Number(runSql(`SELECT COUNT(*) FROM chats WHERE account='${sqlEscape(_account)}';`).trim() || 0);
  } catch (e) { report.errors.push({ name: 'chats', error: String(e.message || e) }); }
  try {
    const r = opencli(['facebook', 'whoami', '-f', 'json'], { json: true });
    if (r.status === 0) { const me = tryParseJson(r.stdout); if (me) setMeta('whoami', JSON.stringify(me)); }
  } catch { /* */ }
  setMeta('last_sync', ts);
  setMeta('last_sync_report', JSON.stringify(report));
  report.ok = report.errors.length === 0;
  report.store = DB_PATH;
  report.synced_at = ts;
  if (g.json) console.log(JSON.stringify(stamp(report, 'sync'), null, 2));
  else {
    console.log(`fb sync ${report.ok ? 'OK' : 'PARTIAL'}`);
    console.log(`  notifications: ${report.notifications}`);
    console.log(`  groups:        ${report.groups}`);
    console.log(`  chats:         ${report.chats}`);
    console.log(`  store:         ${DB_PATH}`);
    if (report.errors.length) { console.log('  errors:'); for (const e of report.errors) console.log(`    - ${e.name}: ${e.error}`); }
  }
  process.exit(report.ok ? EXIT.OK : EXIT.OPENCLI_FAIL);
}

function cmdDb(g, args) {
  ensureStore();
  const sub = args[0];
  const queryArgs = args.slice(1);
  const limit = Number(g.limit || 20);
  let sql;
  if (sub === 'notifications') sql = `SELECT notif_id, unread, substr(text,1,120) AS text, time, notif_type FROM notifications WHERE account='${sqlEscape(_account)}' ORDER BY synced_at DESC LIMIT ${limit};`;
  else if (sub === 'chats') sql = `SELECT thread_id, name, substr(snippet,1,80) AS snippet, time, unread FROM chats WHERE account='${sqlEscape(_account)}' ORDER BY synced_at DESC LIMIT ${limit};`;
  else if (sub === 'groups') sql = `SELECT name, last_post, url FROM groups WHERE account='${sqlEscape(_account)}' ORDER BY synced_at DESC LIMIT ${limit};`;
  else if (sub === 'messages') sql = `SELECT id, thread_id, CASE WHEN from_me=1 THEN 'me' ELSE sender END AS who, substr(text,1,200) AS text, time FROM messages WHERE account='${sqlEscape(_account)}' ORDER BY id DESC LIMIT ${limit};`;
  else if (sub === 'search') {
    const q = queryArgs.join(' ').trim();
    if (!q) die('Usage: fb db search <query>', EXIT.USAGE, { json: g.json });
    sql = `SELECT 'notif' AS kind, text AS body, url AS ref FROM notifications WHERE text LIKE '%${sqlEscape(q)}%' AND account='${sqlEscape(_account)}' UNION ALL SELECT 'chat', name || ': ' || snippet, url FROM chats WHERE (name LIKE '%${sqlEscape(q)}%' OR snippet LIKE '%${sqlEscape(q)}%') AND account='${sqlEscape(_account)}' UNION ALL SELECT 'group', name, url FROM groups WHERE name LIKE '%${sqlEscape(q)}%' AND account='${sqlEscape(_account)}' LIMIT ${limit};`;
  } else die('Usage: fb db notifications|chats|groups|messages|search', EXIT.USAGE, { json: g.json });
  if (g.json) { const out = runSql(`.mode json\n${sql}`); console.log(out.trim() || '[]'); process.exit(EXIT.OK); }
  const out = runSql(`.mode column\n.headers on\n${sql}`);
  process.stdout.write(out.endsWith('\n') ? out : out + '\n');
  process.exit(EXIT.OK);
}

function parseSendArgs(argv) {
  let to = null, message = null; const rest = [];
  for (let i = 0; i < argv.length; i += 1) {
    const a = argv[i];
    if (a === '--to' || a === '-t') to = argv[++i];
    else if (a === '--message' || a === '-m') message = argv[++i];
    else rest.push(a);
  }
  if (!to && rest.length) to = rest.shift();
  if (!message && rest.length) message = rest.join(' ');
  return { to, message };
}

// ─── per-subcommand help ────────────────────────────────────────────────────
function helpFor(sub) {
  const help = (s) => s;
  if (sub === 'version') return `fb version — print version, paths, CDP endpoint, account\n\n  ${PROGRAM} version [--json]`;
  if (sub === 'completion') return `fb completion <bash|zsh|fish|pwsh> — emit shell completion script\n\n  eval "$(fb completion bash)"\n  fb completion zsh > _fb && fpath+=. && autoload -U _fb && compinit\n  fb completion fish | source\n  fb completion pwsh > completer.ps1`;
  if (sub === 'docs') return `fb docs — print repo / docs URL`;
  if (sub === 'accounts') return `fb accounts — manage named accounts\n\n  fb accounts list | add <name> | use <name> | rm <name>`;
  if (sub === 'store') return `fb store — local SQLite store introspection\n\n  fb store info | prune [days] | reset | lock [wait]`;
  if (sub === 'profile') return `fb profile — public profile lookup or own profile\n\n  fb profile <username> | set --display <name> | whoami`;
  if (sub === 'messages') return `fb messages — local store queries (offline after sync)\n\n  fb messages list [chat] [since] | show <id> | search <query>`;
  if (sub === 'sync') return `fb sync — pull notifications/groups/chats into the local SQLite store\n\n  fb sync [--limit N] [--timeout 5m]\n  Block writes with --read-only or FB_READONLY=1.`;
  if (sub === 'send') return `fb send — send a Messenger message\n\n  fb send --to <thread_id|url> --message "text"\n  fb send <thread_id> "text"  # positional shorthand`;
  if (sub === 'db') return `fb db — raw local-store queries\n\n  fb db notifications | chats | groups | messages [--limit N]\n  fb db search <query>`;
  if (sub === 'daemon') return `fb daemon — opencli daemon manager (lightweight, no GUI mgmt)\n\n  fb daemon start | stop | restart | status\n  (No more wmctrl/xdotool/hide — just opencli)`;
  if (sub === 'doctor') return `fb doctor — opencli + FB session + store diagnostics`;
  if (sub === 'status') return `fb status — auth + cdp + store + last sync + FTS counts`;
  if (sub === 'whoami') return `fb whoami — show the logged-in Facebook account (via opencli)`;
  if (sub === 'auth' || sub === 'login') return `fb auth | login — visible login (foreground window, one-time)`;
  if (sub === 'setup' || sub === 'connect' || sub === 'onboard') return `fb setup — guided one-time connect (extension install → FB login → done)`;
  if (sub === 'home' || sub === 'feed') return `fb home | feed — home/feed timeline (live)`;
  if (sub === 'notifications' || sub === 'notifs') return `fb notifications | notifs — list notifications (live)`;
  if (sub === 'groups') return `fb groups — list groups (live)`;
  if (sub === 'friends') return `fb friends — list friends (live)`;
  if (sub === 'search') return `fb search <query> — top results (mixed, live)`;
  if (sub === 'posts' || sub === 'search-posts') return `fb posts <query> [--limit N] — public post search (live)`;
  if (sub === 'post' || sub === 'read-post') return `fb post <url|fbid> — deep-read one public post/photo/reel (live)`;
  if (sub === 'research') return `fb research <query> [--limit N] — posts search + deep-read top N`;
  if (sub === 'chats' || sub === 'inbox') return `fb chats | inbox — list Messenger chats (live)`;
  if (sub === 'thread' || sub === 'read') return `fb thread <thread_id|url> [--limit N] — read one Messenger thread`;
  if (sub === 'media' || sub === 'pull') return `fb media | pull <thread|post-url> [--out DIR] [--limit N] [--keep]`;
  if (sub === 'open') return `fb open <path> — open a downloaded file with the system viewer`;
  if (sub === 'keep') return `fb keep <file|thread> — move tmp file(s) to keep/`;
  if (sub === 'purge') return `fb purge [thread|all] — delete tmp downloads`;
  if (sub === 'add-friend') return `fb add-friend <username> — send a friend request`;
  if (sub === 'join-group') return `fb join-group <group> — join a group`;
  if (sub === 'events') return `fb events [--limit N] — list events (live)`;
  if (sub === 'memories') return `fb memories [--limit N] — list memories (live)`;
  if (sub === 'marketplace') return `fb marketplace listings|inbox [--limit N] — Marketplace queries (live)`;
  return null;
}

