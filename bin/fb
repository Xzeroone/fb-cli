// ════════════════════════════════════════════════════════════════════════════
// DISPATCHER
// ════════════════════════════════════════════════════════════════════════════
function main() {
  _t0 = Date.now();
  const g = parseArgs(process.argv.slice(2));
  _jsonActive = g.json;
  _eventsOn = g.events;
  _readOnlyActive = g.readOnly;
  process.env.FB_ACCOUNT = g.account;

  if (g.store) process.env.FB_STORE_DIR = g.store;
  const realStoreDir = g.store || process.env.FB_STORE_DIR || DEFAULT_STORE;
  if (realStoreDir !== STORE_DIR) { /* env already updated above */ }

  emitEvent('cli.start', { version: VERSION, argv: process.argv.slice(2) });
  if (g.version) { cmdVersion(g); return; }
  if (g.help && g.rest.length === 0) { console.log(HELP.default()); process.exit(EXIT.OK); }
  if (g.rest.length === 0) { console.log(HELP.default()); process.exit(EXIT.USAGE); }
  const [cmd, ...args] = g.rest;
  if (g.help) {
    const h = helpFor(cmd);
    if (h) { console.log(h); process.exit(EXIT.OK); }
    console.log(HELP.default()); process.exit(EXIT.OK);
  }

  switch (cmd) {
    case 'setup': case 'connect': case 'onboard': cmdSetup(g); break;
    case 'daemon': cmdDaemon(g, args); break;
    case 'auth': case 'login':
      console.error('fb auth: using visible browser for login (one-time). After success, fb stays invisible.');
      rejectIfReadOnly('login (auth)');
      printRaw(opencli(['facebook', 'login', '--window', 'foreground'], { json: false, timeout: 600000, windowMode: 'foreground' }), { json: g.json });
      break;
    case 'whoami': runFacebook('whoami', [], g); break;
    case 'status': case 'check': cmdStatus(g); break;
    case 'doctor': cmdDoctor(g); break;
    case 'version': cmdVersion(g); break;
    case 'completion': cmdCompletion(g, args); break;
    case 'accounts': cmdAccounts(g, args); break;
    case 'store': cmdStore(g, args); break;
    case 'docs': cmdDocs(g); break;
    case 'profile': cmdProfile(g, args); break;
    case 'sync': cmdSync(g); break;
    case 'home': case 'feed': runFacebook('feed', [], g); break;
    case 'notifications': case 'notifs': runFacebook('notifications', [], g); break;
    case 'groups': runFacebook('groups', [], g); break;
    case 'friends': runFacebook('friends', [], g); break;
    case 'search':
      if (!args[0]) die('Usage: fb search <query>', EXIT.USAGE, { json: g.json });
      runFacebook('search', [args.join(' ')], g); break;
    case 'posts': case 'search-posts':
      if (!args[0]) die('Usage: fb posts <query>', EXIT.USAGE, { json: g.json });
      runFacebook('search-posts', [args.join(' ')], g); break;
    case 'post': case 'read-post':
      if (!args[0]) die('Usage: fb post <url|fbid>', EXIT.USAGE, { json: g.json });
      runFacebook('post', [args[0]], g); break;
    case 'research': {
      if (!args[0]) die('Usage: fb research <query> [--limit N]', EXIT.USAGE, { json: g.json });
      const q = args.join(' ');
      const lim = Number(g.limit || 5);
      const search = opencli(['facebook', 'search-posts', q, '--limit', String(lim), '-f', 'json'], { json: true, timeout: 180000, windowMode: effectiveWindow(g) });
      if (search.status !== 0) { printRaw(search, { json: g.json }); break; }
      const hits = asRows(tryParseJson(search.stdout));
      const report = stamp({ query: q, count: hits.length, posts: [] }, 'research');
      for (const hit of hits.slice(0, lim)) {
        const url = hit.url || hit.Url;
        const entry = { search: hit, detail: null, error: null };
        if (url) {
          const deep = opencli(['facebook', 'post', url, '-f', 'json'], { json: true, timeout: 120000, windowMode: effectiveWindow(g) });
          if (deep.status === 0) { const rows = asRows(tryParseJson(deep.stdout)); entry.detail = rows[0] || null; }
          else entry.error = (deep.stderr || deep.stdout || 'deep-read failed').trim().slice(0, 240);
        } else entry.error = 'no public url in search hit';
        report.posts.push(entry);
      }
      if (g.json) console.log(JSON.stringify(report, null, 2));
      else {
        console.log(`fb research: ${q}`);
        console.log(`hits: ${report.count}\n`);
        report.posts.forEach((p, i) => {
          const s = p.search || {}; const d = p.detail || {};
          console.log(`── ${i + 1}. ${d.author || s.author || '(unknown)'}  [${d.kind || s.kind || ''}]`);
          console.log(`url: ${d.url || s.url || ''}`);
          const body = d.text || s.summary || '';
          console.log(body.slice(0, 420) + (body.length > 420 ? '…' : ''));
          if (d.likes || d.loves || d.reactions) console.log(`reactions: likes=${d.likes || '-'} loves=${d.loves || '-'} other=${d.reactions || '-'} comments=${d.comments_count || '-'}`);
          if (d.links) console.log(`links: ${String(d.links).slice(0, 200)}`);
          if (p.error) console.log(`note: ${p.error}`);
          console.log('');
        });
      }
      process.exit(EXIT.OK);
    }
    case 'chats': case 'inbox':
      runFacebook('messages', [], g); break;
    case 'messages': cmdMessages(g, args); break;
    case 'thread': case 'read':
      if (!args[0]) die('Usage: fb thread <thread_id|url>', EXIT.USAGE, { json: g.json });
      runFacebook('thread', [args[0]], g); break;
    case 'media': case 'pull': case 'download-media': case 'media-download': {
      if (!args[0]) die('Usage: fb pull <thread_id|url> [--out DIR] [--limit N] [--keep]', EXIT.USAGE, { json: g.json });
      const mediaExtra = [args[0]];
      for (let i = 1; i < args.length; i += 1) {
        if (args[i] === '--out' && args[i + 1]) mediaExtra.push('--out', args[++i]);
        else if (args[i] === '--keep') mediaExtra.push('--keep', 'true');
        else if (args[i] === '--limit' && args[i + 1]) g.limit = args[++i];
      }
      runFacebook('media-download', mediaExtra, g);
      break;
    }
    case 'open': {
      const p = args[0];
      if (!p) die('Usage: fb open <path>', EXIT.USAGE, { json: g.json });
      const target = path.resolve(p);
      if (!fs.existsSync(target)) die(`Not found: ${target}`, EXIT.NOT_FOUND, { json: g.json });
      const bin = process.platform === 'darwin' ? 'open' : process.platform === 'win32' ? 'cmd' : 'xdg-open';
      const argv = process.platform === 'win32' ? ['/c', 'start', '', target] : [target];
      const child = spawn(bin, argv, { detached: true, stdio: 'ignore' });
      child.unref();
      console.log(`opened: ${target}`);
      process.exit(EXIT.OK);
    }
    case 'keep': {
      ensureStore();
      const src = args[0];
      if (!src) die('Usage: fb keep <file-or-thread-id>', EXIT.USAGE, { json: g.json });
      const keepRoot = path.join(STORE_DIR, 'keep');
      fs.mkdirSync(keepRoot, { recursive: true });
      let fromPath = path.resolve(src);
      if (!fs.existsSync(fromPath)) fromPath = path.join(STORE_DIR, 'tmp', src);
      if (!fs.existsSync(fromPath)) die(`Not found: ${src}`, EXIT.NOT_FOUND, { json: g.json });
      const st = fs.statSync(fromPath);
      if (st.isDirectory()) {
        const dest = path.join(keepRoot, path.basename(fromPath));
        fs.mkdirSync(dest, { recursive: true });
        for (const name of fs.readdirSync(fromPath)) {
          if (name === 'manifest.json') continue;
          fs.renameSync(path.join(fromPath, name), path.join(dest, name));
        }
        const man = path.join(fromPath, 'manifest.json');
        if (fs.existsSync(man)) fs.copyFileSync(man, path.join(dest, 'manifest.json'));
        console.log(`kept directory → ${dest}`);
      } else {
        const dest = path.join(keepRoot, path.basename(fromPath));
        fs.renameSync(fromPath, dest);
        console.log(`kept → ${dest}`);
      }
      process.exit(EXIT.OK);
    }
    case 'purge': {
      const target = args[0] || 'all';
      if (!fs.existsSync(TMP_DIR)) { console.log('nothing to purge'); process.exit(EXIT.OK); }
      if (target === 'all') { fs.rmSync(TMP_DIR, { recursive: true, force: true }); fs.mkdirSync(TMP_DIR, { recursive: true }); console.log(`purged all temp media under ${TMP_DIR}`); }
      else {
        const dir = path.join(TMP_DIR, target);
        if (!fs.existsSync(dir)) die(`No tmp folder for thread: ${target}`, EXIT.NOT_FOUND, { json: g.json });
        fs.rmSync(dir, { recursive: true, force: true });
        console.log(`purged ${dir}`);
      }
      process.exit(EXIT.OK);
    }
    case 'send': {
      const { to, message } = parseSendArgs(args);
      if (!to || !message) die('Usage: fb send --to <thread_id|url> --message "text"', EXIT.USAGE, { json: g.json });
      rejectIfReadOnly('send message');
      runFacebook('send-message', ['--to', to, '--message', message], g);
      break;
    }
    case 'add-friend':
      if (!args[0]) die('Usage: fb add-friend <username>', EXIT.USAGE, { json: g.json });
      rejectIfReadOnly('add friend');
      runFacebook('add-friend', [args[0]], g); break;
    case 'join-group':
      if (!args[0]) die('Usage: fb join-group <group>', EXIT.USAGE, { json: g.json });
      rejectIfReadOnly('join group');
      runFacebook('join-group', [args[0]], g); break;
    case 'events': runFacebook('events', [], g); break;
    case 'memories': runFacebook('memories', [], g); break;
    case 'marketplace': {
      const sub = args[0];
      if (sub === 'listings' || sub === 'list') runFacebook('marketplace-listings', args.slice(1), g);
      else if (sub === 'inbox') runFacebook('marketplace-inbox', args.slice(1), g);
      else die('Usage: fb marketplace listings|inbox', EXIT.USAGE, { json: g.json });
      break;
    }
    case 'db': cmdDb(g, args); break;
    case 'help':
      if (args[0]) {
        const h = helpFor(args[0]);
        if (h) { console.log(h); process.exit(EXIT.OK); }
        die(`no help for: ${args[0]}`, EXIT.USAGE, { json: g.json });
      }
      console.log(HELP.default());
      process.exit(EXIT.OK);
    default:
      console.error(`Unknown command: ${cmd}\n`);
      console.log(HELP.default());
      process.exit(EXIT.USAGE);
  }
}

let _account = 'default';
function mainWrapper() {
  const g = parseArgs(process.argv.slice(2));
  _account = g.account || 'default';
  _jsonActive = g.json;
  _eventsOn = g.events;
  _readOnlyActive = g.readOnly;
  return main();
}

function cmdSetup(g) {
  // Non-interactive mode: print what the human needs to do, but don't open
  // any URLs and don't poll. Useful for CI, agents, headless servers.
  if (process.env.FB_SETUP_NONINTERACTIVE === '1') {
    console.log('fb setup (non-interactive)');
    console.log('');
    console.log('Open these URLs in Chrome, then re-run without FB_SETUP_NONINTERACTIVE=1:');
    console.log('  1. Install OpenCLI extension:');
    console.log(`     ${process.env.FB_OPENCLI_EXT_URL || 'https://chromewebstore.google.com/detail/opencli/ildkmabpimmkaediidaifkhjpohdnifk'}`);
    console.log('  2. Log into Facebook:');
    console.log('     https://www.facebook.com/login');
    console.log('');
    process.exit(EXIT.OK);
  }
  const timeoutMs = Number(process.env.FB_SETUP_TIMEOUT_MS || 10 * 60 * 1000);
  const pollMs = Number(process.env.FB_SETUP_POLL_MS || 4000);
  const started = Date.now();
  console.log('');
  console.log('╔══════════════════════════════════════════════════════╗');
  console.log('║  fb setup — connect once, then everything is magic  ║');
  console.log('╚══════════════════════════════════════════════════════╝');
  console.log('');
  console.log('You only need to click a few things in Chrome.');
  console.log('I will open the right tabs and wait.');
  console.log('');

  // open-url: xdg-open on Linux, open on macOS, never fail loud
  function openUrl(url) {
    const opener = process.env.FB_OPEN_CMD || (process.platform === 'darwin' ? 'open' : 'xdg-open');
    try {
      const child = spawn(opener, [url], { detached: true, stdio: 'ignore' });
      child.unref();
      return true;
    } catch { return false; }
  }

  spawnSync(OPENCLI, ['daemon', 'restart'], { encoding: 'utf8', timeout: 30000 });
  sleepMs(1500);

  let d = doctorConnected();
  if (d.ok) console.log('✓ OpenCLI extension already connected');
  else {
    console.log('Step 1/2 — Install OpenCLI extension');
    console.log('  → Opening Chrome Web Store…');
    console.log('  → Click  "Add to Chrome"  /  "Install"  in the tab that opens');
    const url = process.env.FB_OPENCLI_EXT_URL || 'https://chromewebstore.google.com/detail/opencli/ildkmabpimmkaediidaifkhjpohdnifk';
    console.log(`  → ${url}`);
    console.log('');
    if (!openUrl(url)) {
      console.log(`  ! Could not open browser automatically. Open this URL manually:`);
      console.log(`    ${url}`);
    }
    process.stdout.write('  Waiting for extension');
    while (Date.now() - started < timeoutMs) {
      d = doctorConnected();
      if (d.ok) { console.log(''); console.log('✓ Extension connected'); break; }
      process.stdout.write('.'); sleepMs(pollMs);
    }
    if (!d.ok) { console.log(''); console.error('✗ Timed out waiting for OpenCLI extension.'); process.exit(EXIT.INTERNAL); }
  }

  let auth = facebookLoggedIn();
  if (auth.ok) console.log(`✓ Facebook already logged in (user_id=${auth.me.user_id || '?'})`);
  else {
    console.log('');
    console.log('Step 2/2 — Log into Facebook');
    console.log('  → Opening Facebook login…');
    console.log('  → Sign in / complete 2FA in the browser tab');
    console.log('');
    if (!openUrl('https://www.facebook.com/login')) {
      console.log('  ! Could not open browser. Open https://www.facebook.com/login manually.');
    }
    spawn(OPENCLI, ['facebook', 'login', '--window', 'foreground'], { detached: true, stdio: 'ignore', env: { ...process.env, OPENCLI_WINDOW: 'foreground' } }).unref();
    process.stdout.write('  Waiting for Facebook session');
    while (Date.now() - started < timeoutMs) {
      auth = facebookLoggedIn();
      if (auth.ok) { console.log(''); console.log(`✓ Logged in (user_id=${auth.me.user_id || '?'})`); break; }
      process.stdout.write('.'); sleepMs(pollMs);
    }
    if (!auth.ok) { console.log(''); console.error('✗ Timed out waiting for Facebook login.'); process.exit(EXIT.INTERNAL); }
  }

  if (auth.me?.user_id) {
    const ts = nowIso();
    const display = auth.me.name || auth.me.display_name || null;
    runSql(
      `INSERT INTO accounts(name,user_id,display_name,last_used_at,created_at) VALUES('default','${sqlEscape(auth.me.user_id)}', ${display ? `'${sqlEscape(display)}'` : 'NULL'}, '${ts}', '${ts}') ON CONFLICT(name) DO UPDATE SET user_id=excluded.user_id, display_name=COALESCE(excluded.display_name, accounts.display_name), last_used_at=excluded.last_used_at;`,
    );
  }
  setMeta('last_setup', nowIso());

  console.log('');
  console.log('══════════════════════════════════════════════════════');
  console.log('  All set. Rest is magic.');
  console.log('');
  console.log('  Try:');
  console.log('    fb whoami');
  console.log('    fb chats --limit 10');
  console.log('    fb posts "something" --limit 5');
  console.log('══════════════════════════════════════════════════════');
  console.log('');

  if (g.json) console.log(JSON.stringify(stamp({ ok: true, extension: true, authenticated: true, user_id: auth.me?.user_id || null }, 'setup'), null, 2));
  process.exit(EXIT.OK);
}

try {
  mainWrapper();
} catch (err) {
  console.error(`fb error: ${err instanceof Error ? err.message : err}`);
  emitEvent('cli.error', { message: String(err?.message || err) });
  process.exit(EXIT.INTERNAL);
}
