#!/usr/bin/env bash
# fb-service — install/manage systemd user units for fb (v0.7 headless stack).
set -euo pipefail

UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
OPENCLI_UNIT="fb-opencli.service"
HEADLESS_UNIT="fb-headless.service"
# legacy units we disable on install
LEGACY_UNITS=(fb-hide.timer fb-hide.service fb-chrome-lean.service)

ROOT_HINT="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd || true)"
REPO_SYSTEMD=""
for cand in \
  "${FB_CLI_ROOT:-}/systemd" \
  "$ROOT_HINT/systemd" \
  "$HOME/.local/share/fb-cli/systemd" \
  "$HOME/fb-cli/systemd"
do
  if [ -f "$cand/fb-opencli.service" ]; then
    REPO_SYSTEMD="$cand"
    break
  fi
done

usage() {
  cat <<'EOF'
fb-service — install/manage fb systemd user units (v0.7)

  fb-service install       opencli daemon + headless Chrome on :9223
  fb-service uninstall     disable + stop units
  fb-service start|stop|restart|status
  fb-service linger-on     survive logout (loginctl enable-linger)
  fb-service linger-off

Stack:
  • fb-opencli.service    Node bridge on :19825 (~60–80 MB)
  • fb-headless.service   Headless Chrome CDP on :9223 (minimal profile)

Legacy (disabled on install): fb-hide.*, fb-chrome-lean.service
EOF
}

need_systemctl() {
  command -v systemctl >/dev/null || { echo "systemctl not found"; exit 1; }
}

find_opencli_daemon_js() {
  local opencli real pkg nm
  opencli="$(command -v opencli 2>/dev/null || true)"
  if [ -z "$opencli" ] && [ -x "$HOME/.npm-global/bin/opencli" ]; then
    opencli="$HOME/.npm-global/bin/opencli"
  fi
  [ -n "$opencli" ] || return 1
  real="$(readlink -f "$opencli" 2>/dev/null || realpath "$opencli" 2>/dev/null || echo "$opencli")"
  pkg="$(cd "$(dirname "$real")/../.." 2>/dev/null && pwd)"
  if [ -f "$pkg/dist/src/daemon.js" ]; then
    echo "$pkg/dist/src/daemon.js"; return 0
  fi
  nm="$(npm root -g 2>/dev/null || true)"
  if [ -n "$nm" ] && [ -f "$nm/@jackwener/opencli/dist/src/daemon.js" ]; then
    echo "$nm/@jackwener/opencli/dist/src/daemon.js"; return 0
  fi
  return 1
}

install_units_from_repo() {
  mkdir -p "$UNIT_DIR"
  local node_bin daemon_js home_dir
  node_bin="$(command -v node)"
  home_dir="$HOME"
  daemon_js="$(find_opencli_daemon_js)" || {
    echo "fb-service: could not find opencli daemon.js (npm i -g @jackwener/opencli)" >&2
    return 1
  }

  if [ -n "$REPO_SYSTEMD" ] && [ -f "$REPO_SYSTEMD/fb-opencli.service" ]; then
    sed \
      -e "s|__NODE__|$node_bin|g" \
      -e "s|__OPENCLI_DAEMON__|$daemon_js|g" \
      "$REPO_SYSTEMD/fb-opencli.service" > "$UNIT_DIR/fb-opencli.service"
  else
    cat > "$UNIT_DIR/fb-opencli.service" <<EOF
[Unit]
Description=fb/opencli bridge daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=$node_bin $daemon_js
WorkingDirectory=$home_dir
Environment=HOME=$home_dir
Environment=PATH=$home_dir/.local/bin:$home_dir/bin:$home_dir/.npm-global/bin:/usr/local/bin:/usr/bin:/bin
Environment=OPENCLI_WINDOW=background
Environment=NODE_ENV=production
MemoryMax=128M
Restart=on-failure
RestartSec=3
KillMode=mixed
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fb-opencli

[Install]
WantedBy=default.target
EOF
  fi

  if [ -n "$REPO_SYSTEMD" ] && [ -f "$REPO_SYSTEMD/fb-headless.service" ]; then
    cp "$REPO_SYSTEMD/fb-headless.service" "$UNIT_DIR/fb-headless.service"
  else
    cat > "$UNIT_DIR/fb-headless.service" <<EOF
[Unit]
Description=fb headless Chrome CDP (:9223)
After=network-online.target fb-opencli.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=$home_dir/bin/fb-headless start
ExecStop=$home_dir/bin/fb-headless stop
Environment=HOME=$home_dir
Environment=PATH=$home_dir/bin:$home_dir/.local/bin:$home_dir/.npm-global/bin:/usr/local/bin:/usr/bin:/bin
TimeoutStartSec=60
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fb-headless

[Install]
WantedBy=default.target
EOF
  fi
}

disable_legacy() {
  local u
  for u in "${LEGACY_UNITS[@]}"; do
    systemctl --user disable --now "$u" 2>/dev/null || true
  done
}

cmd_install() {
  need_systemctl
  chmod +x "$HOME/bin/fb-headless" "$HOME/bin/fb" 2>/dev/null || true
  install_units_from_repo
  disable_legacy
  systemctl --user daemon-reload
  # Prefer unit-owned opencli daemon
  if command -v opencli >/dev/null; then
    opencli daemon stop 2>/dev/null || true
    sleep 0.4
  fi
  systemctl --user enable --now "$OPENCLI_UNIT"
  systemctl --user enable --now "$HEADLESS_UNIT"
  echo "Installed headless stack:"
  echo "  systemctl --user status $OPENCLI_UNIT"
  echo "  systemctl --user status $HEADLESS_UNIT"
  systemctl --user --no-pager --full status "$OPENCLI_UNIT" 2>&1 | head -15 || true
  echo "---"
  systemctl --user --no-pager --full status "$HEADLESS_UNIT" 2>&1 | head -15 || true
  echo
  echo "Survive logout:  fb-service linger-on"
  echo "Check:           fb whoami"
}

cmd_uninstall() {
  need_systemctl
  systemctl --user disable --now "$HEADLESS_UNIT" 2>/dev/null || true
  systemctl --user disable --now "$OPENCLI_UNIT" 2>/dev/null || true
  disable_legacy
  systemctl --user daemon-reload
  echo "fb user services disabled."
}

case "${1:-}" in
  install) cmd_install ;;
  uninstall) cmd_uninstall ;;
  start)
    need_systemctl
    systemctl --user start "$OPENCLI_UNIT" "$HEADLESS_UNIT"
    ;;
  stop)
    need_systemctl
    systemctl --user stop "$HEADLESS_UNIT" "$OPENCLI_UNIT"
    ;;
  restart)
    need_systemctl
    systemctl --user restart "$OPENCLI_UNIT"
    systemctl --user restart "$HEADLESS_UNIT"
    ;;
  status)
    need_systemctl
    systemctl --user --no-pager --full status "$OPENCLI_UNIT" 2>&1 | head -20
    echo "---"
    systemctl --user --no-pager --full status "$HEADLESS_UNIT" 2>&1 | head -20
    echo "---"
    "$HOME/bin/fb-headless" status 2>&1 || true
    "$HOME/bin/fb" status 2>&1 | head -15 || true
    ;;
  linger-on) loginctl enable-linger "$USER"; echo "linger enabled for $USER" ;;
  linger-off) loginctl disable-linger "$USER"; echo "linger disabled" ;;
  -h|--help|help|"") usage ;;
  *) echo "Unknown: $1"; usage; exit 2 ;;
esac
