#!/usr/bin/env bash
# fb Chrome backend — NEVER starts a second Chrome when one is already running.
# Uses your real Default profile only. Goal: no surprise chrome windows.
set -euo pipefail

USER_DATA="${FB_CHROME_USER_DATA:-$HOME/.config/google-chrome}"
PROFILE_DIR="${FB_CHROME_PROFILE_DIR:-Default}"
CHROME="${CHROME_BIN:-/usr/bin/google-chrome}"
# attach = only wait on existing Chrome (safest, no new windows)
# auto   = attach if running; only start Chrome if none exists (off-screen)
MODE="${FB_CHROME_MODE:-attach}"

log() { echo "[fb-chrome-lean] $*" >&2; }

main_chrome_pids() {
  # Main browser processes only (not --type=renderer/gpu/...)
  pgrep -af 'google-chrome|chromium' 2>/dev/null | while read -r line; do
    case "$line" in
      *--type=*) continue ;;
    esac
    # pid is first field
    echo "$line" | awk '{print $1}'
  done
}

hide_chrome() {
  command -v wmctrl >/dev/null 2>&1 || return 0
  wmctrl -lx 2>/dev/null | awk '/google-chrome|Chromium|Google-chrome/{print $1}' | while read -r id; do
    [[ -z "$id" ]] && continue
    wmctrl -i -r "$id" -b add,hidden,below 2>/dev/null || true
    wmctrl -i -r "$id" -e '0,-32000,-32000,100,100' 2>/dev/null || true
  done
}

wait_on_pids() {
  local pids=("$@")
  [[ ${#pids[@]} -eq 0 ]] && return 1
  log "attached to existing Chrome (profile=$PROFILE_DIR) — no new instance"
  while true; do
    local alive=0
    for p in "${pids[@]}"; do
      if kill -0 "$p" 2>/dev/null; then alive=1; break; fi
    done
    [[ $alive -eq 1 ]] || break
    hide_chrome
    sleep 45
  done
  log "Chrome exited"
}

mapfile -t PIDS < <(main_chrome_pids || true)

if [[ ${#PIDS[@]} -gt 0 ]]; then
  wait_on_pids "${PIDS[@]}"
  exit 0
fi

if [[ "$MODE" == "attach" ]]; then
  log "no Chrome running — waiting for you to open Chrome (will not spawn a new process)"
  # Stay alive and attach when user opens Chrome (systemd keeps us running)
  while true; do
    mapfile -t PIDS < <(main_chrome_pids || true)
    if [[ ${#PIDS[@]} -gt 0 ]]; then
      wait_on_pids "${PIDS[@]}"
      exit 0
    fi
    sleep 15
  done
fi

# auto/hidden/headless: only start if nothing is running
log "starting single Chrome with your profile=$PROFILE_DIR (mode=$MODE)"
extra=()
case "$MODE" in
  headless) extra+=(--headless=new --disable-gpu) ;;
  *) extra+=(--window-position=-32000,-32000 --window-size=100,100) ;;
esac

# Single instance: Chrome will attach to existing if race; we prefer not racing.
exec "$CHROME" \
  --user-data-dir="$USER_DATA" \
  --profile-directory="$PROFILE_DIR" \
  --no-first-run \
  --no-default-browser-check \
  --disable-session-crashed-bubble \
  "${extra[@]}" \
  about:blank
