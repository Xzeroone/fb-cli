#!/usr/bin/env bash
# fb lean Chrome — ALWAYS uses your real Chrome profile (cookies + OpenCLI extension).
#
# Modes (env FB_CHROME_MODE):
#   auto     (default)  reuse running Chrome if present; else start off-screen with Default
#   hidden              force start off-screen (parked at -32000,-32000)
#   headless            force --headless=new with your profile (invisible; no second GUI)
#
# Never creates a separate empty profile that forces re-login.
set -euo pipefail

USER_DATA="${FB_CHROME_USER_DATA:-$HOME/.config/google-chrome}"
PROFILE_DIR="${FB_CHROME_PROFILE_DIR:-Default}"
CHROME="${CHROME_BIN:-/usr/bin/google-chrome}"
MODE="${FB_CHROME_MODE:-auto}"

log() { echo "[fb-chrome-lean] $*" >&2; }

chrome_pids() {
  # PIDs of chrome processes using this user-data-dir (or default chrome without explicit dir)
  pgrep -f "/opt/google/chrome/chrome|/usr/bin/google-chrome|chrome.*--type=browser" 2>/dev/null | while read -r pid; do
    # skip zygote/helpers if cmd has --type=
    tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null | grep -q -- '--type=' && continue
    echo "$pid"
  done
}

wait_on_pids() {
  local pids=("$@")
  [[ ${#pids[@]} -eq 0 ]] && return 1
  log "using existing Chrome (profile=$PROFILE_DIR) pids=${pids[*]} — no second instance"
  # keep service alive while any main chrome lives
  while true; do
    local alive=0
    for p in "${pids[@]}"; do
      if kill -0 "$p" 2>/dev/null; then alive=1; break; fi
    done
    [[ $alive -eq 1 ]] || break
    # periodically re-hide if GUI peeks
    if command -v wmctrl >/dev/null 2>&1; then
      while read -r id; do
        [[ -z "$id" ]] && continue
        wmctrl -i -r "$id" -b add,hidden,below 2>/dev/null || true
        wmctrl -i -r "$id" -e "0,-32000,-32000,-1,-1" 2>/dev/null || true
      done < <(wmctrl -l 2>/dev/null | awk '/[Cc]hrome|[Cc]hromium/{print $1}')
    fi
    sleep 30
  done
  log "Chrome exited"
  return 0
}

start_with_profile() {
  local extra=()
  case "$MODE" in
    headless)
      # New headless can keep profile + extensions; no visible window.
      extra+=(--headless=new --disable-gpu)
      log "starting Chrome headless=new with profile=$PROFILE_DIR"
      ;;
    hidden|auto)
      # Visible process, parked off-screen (best extension compatibility).
      extra+=(--window-position=-32000,-32000 --window-size=1200,800)
      log "starting Chrome off-screen with profile=$PROFILE_DIR"
      ;;
    *)
      log "unknown FB_CHROME_MODE=$MODE (use auto|hidden|headless)"; exit 2
      ;;
  esac

  # Critical: same user-data-dir + profile-directory as daily Chrome
  # so c_user cookies + OpenCLI extension id ildkmabpimmkaediidaifkhjpohdnifk are already there.
  exec "$CHROME" \
    --user-data-dir="$USER_DATA" \
    --profile-directory="$PROFILE_DIR" \
    --no-first-run \
    --no-default-browser-check \
    --disable-session-crashed-bubble \
    --disable-features=Translate,MediaRouter,DialMediaRouteProvider \
    --renderer-process-limit=4 \
    --process-per-site \
    --disk-cache-size=1048576 \
    --media-cache-size=1048576 \
    --mute-audio \
    --noerrdialogs \
    "${extra[@]}" \
    "https://www.facebook.com/"
}

# --- main ---
mapfile -t PIDS < <(chrome_pids || true)

if [[ "$MODE" == "auto" || "$MODE" == "hidden" ]]; then
  if [[ ${#PIDS[@]} -gt 0 ]]; then
    # Already running with your profile — DO NOT launch another (single-instance handoff).
    wait_on_pids "${PIDS[@]}"
    exit 0
  fi
fi

# headless mode always starts its own process (may fail if GUI chrome locks profile —
# then fall back to wait-on-existing)
if [[ "$MODE" == "headless" ]]; then
  if [[ ${#PIDS[@]} -gt 0 ]]; then
    log "GUI Chrome already holds the profile; attaching instead of second headless instance"
    wait_on_pids "${PIDS[@]}"
    exit 0
  fi
fi

start_with_profile
